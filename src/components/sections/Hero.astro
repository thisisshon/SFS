---
/**
 * Hero - THE shared hero band (rule 7). Dark V4 is the ONLY surface.
 *
 * Three types, one component:
 *   1. One-column  - the default. breadcrumb → h1 → lead → cta stacked left,
 *      vertically centred in the tall band.
 *   2. Two-column  - add an `aside` slot (form / card). Renders `.hero-grid`:
 *      the LEFT column is the one-column hero verbatim (breadcrumb folded in),
 *      the aside sits spaced apart on the right. Collapses to a stack ≤980px.
 *   3. Calculator  - pass `calc`. Same dark hero pinned to the shared fixed
 *      calc-hero height (`.hero-calc` = 408px, the tallest calc hero) so every
 *      calculator page's hero is identical in height.
 *
 * Because the hero markup lives here, sitewide hero changes (button style,
 * width, spacing, a new element) are a SINGLE edit to this file + global.css,
 * never a per-page sweep.
 *
 * Props
 *   breadcrumb?  trail passed to <Breadcrumb> (folded INTO .hero-inner)
 *   cta?         single primary button { label, href } (or use the `cta` slot)
 *   calc?        Type 3 - pin to the shared calc-hero height (`.hero-calc`)
 *   reveal?      emit the `data-enter` scroll-reveal hook (default true;
 *                pass false for the few static heroes without the animation)
 *   id / dataSection  section attributes (defaults sec-hero / hero)
 *
 * Slots
 *   eyebrow  optional line above the H1
 *   title    H1 inner (rich markup, e.g. <span class="g">) - required
 *   lead     lead paragraph inner (omit -> no lead)
 *   cta      custom CTA markup (multi-button heroes); wrapped in `.cta`
 *   aside    Type 2 form / card - promotes the hero to a two-column grid
 *   default  extra content appended inside `.hero-inner` (chips, pills, ...)
 */
import Breadcrumb from '../site/Breadcrumb.astro';

interface CrumbItem { name: string; href?: string }
interface Cta { label: string; href: string }
interface Props {
  breadcrumb?: CrumbItem[];
  cta?: Cta;
  calc?: boolean;
  reveal?: boolean;
  id?: string;
  dataSection?: string;
}

const {
  breadcrumb,
  cta,
  calc = false,
  reveal = true,
  id = 'sec-hero',
  dataSection = 'hero',
} = Astro.props;

const hasAside = Astro.slots.has('aside');
const showCta = Boolean(cta) || Astro.slots.has('cta');
---

<section class:list={['hero', 'hero-dark', { 'hero-calc': calc }]} id={id} data-section={dataSection}>
  {hasAside ? (
    <div class="hero-grid">
      <div class="hero-inner" data-enter={reveal ? '' : undefined}>
        {breadcrumb && <Breadcrumb trail={breadcrumb} />}
        {Astro.slots.has('eyebrow') && <p class="hero-eyebrow"><slot name="eyebrow" /></p>}
        <h1><slot name="title" /></h1>
        {Astro.slots.has('lead') && <p class="lead"><slot name="lead" /></p>}
        {showCta && (
          <div class="cta">
            {cta && <a class="btn btn-primary" href={cta.href}>{cta.label}</a>}
            <slot name="cta" />
          </div>
        )}
        <slot />
      </div>
      <slot name="aside" />
    </div>
  ) : (
    <div class="hero-inner" data-enter={reveal ? '' : undefined}>
      {breadcrumb && <Breadcrumb trail={breadcrumb} />}
      {Astro.slots.has('eyebrow') && <p class="hero-eyebrow"><slot name="eyebrow" /></p>}
      <h1><slot name="title" /></h1>
      {Astro.slots.has('lead') && <p class="lead"><slot name="lead" /></p>}
      {showCta && (
        <div class="cta">
          {cta && <a class="btn btn-primary" href={cta.href}>{cta.label}</a>}
          <slot name="cta" />
        </div>
      )}
      <slot />
    </div>
  )}
</section>
