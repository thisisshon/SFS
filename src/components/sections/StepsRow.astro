---
/**
 * StepsRow - the SINGLE-ROW process stepper (the unified new step system's
 * one-row template; its multi-row sibling is StepsRows.astro).
 *
 * Icon-chip timeline: chips sit evenly across one desktop row joined by a
 * dashed connector that runs from the FIRST chip's centre to the LAST chip's
 * centre (no edge bleed - that's the multi-row behaviour). mWeb (<1024px)
 * stacks the chips into a vertical dashed spine.
 *
 * Use for a process whose steps all fit on one line (roughly <=5). More than
 * that -> use StepsRows with `perRow`. Icons come from the shared stepIcons
 * set (rule 4, 24px, currentColor).
 */
import { STEP_ICONS as ICONS } from './stepIcons';

interface Step {
  icon: string;
  title: string;
  desc: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
const lastIndex = steps.length - 1;
---

<div class="msteps msteps-1" style={`--n:${steps.length}`} data-reveal-row>
  <div class="ms-line" aria-hidden="true"></div>
  <div class="ms-track">
    {steps.map((s, i) => (
      <div class:list={['ms-item', { 'ms-tail': i === lastIndex }]}>
        <div class="ms-chip"><Fragment set:html={ICONS[s.icon] ?? ''} /></div>
        <div class="ms-tx">
          <p class="ms-title">{s.title}</p>
          <p class="ms-desc">{s.desc}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .msteps-1 { position: relative; width: 100%; }

  /* ---- base = mWeb: one vertical dashed spine through every chip ---- */
  .ms-line { display: none; }
  .ms-track { display: flex; flex-direction: column; }
  .ms-item { position: relative; display: flex; align-items: flex-start; gap: 16px; padding-bottom: 32px; }
  .ms-item.ms-tail { padding-bottom: 0; }
  .ms-item:not(.ms-tail)::before {
    content: '';
    position: absolute;
    left: 27px; /* 56px chip centre − 1px */
    top: 56px;
    bottom: -8px;
    width: 2px;
    background-image: repeating-linear-gradient(180deg, var(--color-tan-500) 0 7px, transparent 7px 14px);
    z-index: 0;
  }

  .ms-chip {
    position: relative;
    z-index: 1;
    width: 56px; height: 56px; flex: none;
    border-radius: 50%;
    background: var(--color-gold-100);
    color: var(--color-olive-900);
    display: flex; align-items: center; justify-content: center;
  }
  .ms-chip :global(svg) { display: block; width: 24px; height: 24px; }
  :global(.sec-tint) .ms-chip { background: var(--color-surface-section-light); }

  .ms-tx { display: flex; flex-direction: column; gap: 8px; padding-top: 6px; }
  .ms-title { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .ms-desc { font-weight: 400; font-size: 14px; color: var(--color-text-tertiary); }

  /* ---- desktop: even chips in one row + dashed connector first->last ---- */
  @media (min-width: 1024px) {
    .ms-track {
      display: grid;
      grid-template-columns: repeat(var(--n), minmax(0, 1fr));
      column-gap: 24px;
    }
    .ms-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
      padding-bottom: 0;
    }
    .ms-item::before { display: none; }
    .ms-chip { width: auto; height: 64px; padding-inline: 32px; border-radius: 24px; }
    .ms-tx { align-items: center; padding-top: 0; }
    .ms-desc { max-width: 234px; margin-inline: auto; }

    /* connector: first chip centre -> last chip centre (half a column inset
       on each end; no bleed). colw = one exact column, gaps included. */
    .ms-line {
      --colw: calc((100% - (var(--n) - 1) * 24px) / var(--n));
      display: block;
      position: absolute;
      top: 31px; /* 64px chip centre − 1px */
      left: calc(var(--colw) / 2);
      right: calc(var(--colw) / 2);
      height: 2px;
      background-image: repeating-linear-gradient(90deg, var(--color-tan-500) 0 7px, transparent 7px 14px);
      z-index: 0;
    }
  }
</style>
