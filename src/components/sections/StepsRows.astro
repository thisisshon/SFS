---
/**
 * StepsRows - the MULTI-ROW process stepper (the unified new step system's
 * two-plus-row template; its single-row sibling is StepsRow.astro).
 *
 * Icon-chip timeline (the look from the derivatives "How to Start Trading"
 * band). Row 1 fills the row; rows 2+ CENTRE their chips (a 4+3 puts the 3
 * in the middle). Only the dashed connector bleeds - it runs out through the
 * page gutter to the VIEWPORT edge to signal the wrap, reading like text
 * (left-to-right, top-to-bottom):
 *   - first row : from the first chip's centre -> the right screen edge
 *   - middle rows: full screen bleed, left edge -> right edge
 *   - last row  : from the left screen edge -> the last (centred) chip
 * The chips themselves never leave the content column - only the stroke.
 * (A lone row falls back to first-centre -> last-centre.)
 *
 * Desktop (>=1024px): the row grid + edge-bleed connector above.
 * mWeb (<1024px): every chip stacks into one vertical dashed spine.
 *
 * Icons are inline <svg>s (rule 4), 24px, currentColor, in a gold chip.
 * `perRow` defaults to 4.
 */
import { STEP_ICONS as ICONS } from './stepIcons';

interface Step {
  icon: string;
  title: string;
  desc: string;
}
interface Props {
  steps: Step[];
  perRow?: number;
}
const { steps, perRow = 4 } = Astro.props;

// split into rows of `perRow`
const rows: Step[][] = [];
for (let i = 0; i < steps.length; i += perRow) rows.push(steps.slice(i, i + perRow));
const rowCount = rows.length;
const lastIndex = steps.length - 1;

// per-row connector position class
function rowPos(r: number): string {
  if (rowCount === 1) return 'ms-only';
  if (r === 0) return 'ms-first';
  if (r === rowCount - 1) return 'ms-last';
  return 'ms-mid';
}
let gi = 0; // running global index for the mWeb spine's last-item marker
---

<div class="msteps" style={`--per:${perRow}`} data-reveal-row>
  {rows.map((row, r) => (
    <div class:list={['ms-row', rowPos(r)]} style={`--m:${row.length}`}>
      <div class="ms-line" aria-hidden="true"></div>
      {row.map((s) => {
        const isLast = gi++ === lastIndex;
        return (
          <div class:list={['ms-item', { 'ms-tail': isLast }]}>
            <div class="ms-chip"><Fragment set:html={ICONS[s.icon] ?? ''} /></div>
            <div class="ms-tx">
              <p class="ms-title">{s.title}</p>
              <p class="ms-desc">{s.desc}</p>
            </div>
          </div>
        );
      })}
    </div>
  ))}
</div>

<style>
  .msteps { position: relative; width: 100%; display: flex; flex-direction: column; }

  /* ---- base = mWeb: one vertical dashed spine through every chip ---- */
  .ms-row { display: contents; }
  .ms-line { display: none; }
  .ms-item { position: relative; display: flex; align-items: flex-start; gap: 16px; padding-bottom: 32px; }
  .ms-item.ms-tail { padding-bottom: 0; }
  .ms-item:not(.ms-tail)::before {
    content: '';
    position: absolute;
    left: 27px; /* 56px chip centre − 1px */
    top: 56px;
    bottom: -8px;
    width: 2px;
    background-image: repeating-linear-gradient(180deg, var(--color-tan-500) 0 7px, transparent 7px 14px);
    z-index: 0;
  }

  .ms-chip {
    position: relative;
    z-index: 1;
    width: 56px; height: 56px; flex: none;
    border-radius: 50%;
    background: var(--color-gold-100);
    color: var(--color-olive-900);
    display: flex; align-items: center; justify-content: center;
  }
  .ms-chip :global(svg) { display: block; width: 24px; height: 24px; }
  :global(.sec-tint) .ms-chip { background: var(--color-surface-section-light); }

  .ms-tx { display: flex; flex-direction: column; gap: 8px; padding-top: 6px; }
  .ms-title { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .ms-desc { font-weight: 400; font-size: 14px; color: var(--color-text-tertiary); }

  /* ---- desktop: row grids + edge-bleed dashed connector ---- */
  @media (min-width: 1024px) {
    /* Row 1 fills the row (justify-center is a no-op at full width); rows 2+
       centre their chips as a group. One exact column width, gaps included. */
    .ms-row {
      display: flex;
      position: relative;
      justify-content: center;
      column-gap: 24px;
      --colw: calc((100% - (var(--per) - 1) * 24px) / var(--per));
    }
    .msteps { row-gap: 56px; }

    .ms-item {
      flex: 0 0 var(--colw);
      min-width: 0;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
      padding-bottom: 0;
    }
    .ms-item::before { display: none; } /* kill the mWeb spine */
    .ms-chip { width: auto; height: 64px; padding-inline: 32px; border-radius: 24px; }
    .ms-tx { align-items: center; padding-top: 0; }
    .ms-desc { max-width: 234px; margin-inline: auto; }

    .ms-line {
      display: block;
      position: absolute;
      top: 31px; /* 64px chip centre − 1px */
      height: 2px;
      background-image: repeating-linear-gradient(90deg, var(--color-tan-500) 0 7px, transparent 7px 14px);
      z-index: 0;
    }
    /* ONLY the stroke bleeds - out through the page gutter to the viewport
       edge (calc(-1 * --pad) reaches from the content box to the screen).
       first row: first chip centre -> right screen edge;
       middle rows: full screen bleed both sides;
       last row (centred): left screen edge -> last chip centre, where the
       centred group puts the last chip at 50% + (m-1)*(colw/2 + 12px). */
    .ms-first .ms-line { left: calc(var(--colw) / 2); right: calc(-1 * var(--pad)); }
    .ms-mid   .ms-line { left: calc(-1 * var(--pad)); right: calc(-1 * var(--pad)); }
    .ms-last  .ms-line { left: calc(-1 * var(--pad)); right: calc(50% - (var(--m) - 1) * (var(--colw) / 2 + 12px)); }
    .ms-only  .ms-line { left: calc(var(--colw) / 2); right: calc(50% - (var(--m) - 1) * (var(--colw) / 2 + 12px)); }
  }
</style>
