---
/**
 * Footer — brand block + four link columns + legal bar with socials.
 * Markup parity with the legacy <footer>; content from navigation.ts.
 */
import { footerBrand, footerColumns, footerLegal } from '../../data/navigation';
---

<footer>
  <div class="foot-top">
    <div class="foot-brand">
      <div class="fb-logo">
        <span class="fmark"><span>S</span></span><span class="fb-name">&nbsp;{footerBrand.name}</span>
      </div>
      <p class="fb-desc">{footerBrand.description}</p>
      <div class="fb-contact">
        <span>{footerBrand.address}</span>
        <span>{footerBrand.phone}</span>
        <span>{footerBrand.email}</span>
      </div>
    </div>
    {
      footerColumns.map((col) => (
        <div class="foot-col">
          <h5>{col.title}</h5>
          {col.links.map((link) =>
            link.href.startsWith('http') ? (
              <a href={link.href} target="_blank" rel="noopener">
                {link.label}
              </a>
            ) : (
              <a href={link.href}>{link.label}</a>
            )
          )}
        </div>
      ))
    }
  </div>
  <div class="foot-bottom">
    <span class="copy">{footerLegal.copyright}</span>
    <div class="socials">
      <a href="#" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5H17V3.6c-.3-.04-1.3-.13-2.46-.13-2.43 0-4.09 1.48-4.09 4.2v2.34H7.7V13h2.75v8h3.05Z"
          ></path>
        </svg>
      </a>
      <a href="#" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M6.94 8.5H4V20h2.94V8.5ZM5.47 3.9a1.7 1.7 0 1 0 0 3.4 1.7 1.7 0 0 0 0-3.4ZM20 20h-2.94v-6.2c0-1.48-.53-2.49-1.85-2.49-1.01 0-1.61.68-1.88 1.34-.1.24-.12.57-.12.9V20H10.3s.04-10.3 0-11.5h2.94v1.63c.39-.6 1.09-1.46 2.65-1.46 1.94 0 3.4 1.27 3.4 4V20Z"
          ></path>
        </svg>
      </a>
      <a href="#" aria-label="X">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M17.53 3h3.2l-7 8 8.23 10h-6.44l-5.05-6.6L3.9 21H.7l7.49-8.56L.3 3h6.6l4.56 6.03L17.53 3Zm-1.12 16.1h1.77L7.68 4.8H5.78l10.63 14.3Z"
          ></path>
        </svg>
      </a>
      <a href="#" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" stroke="currentColor" stroke-width="1.7"></rect>
          <circle cx="12" cy="12" r="3.6" stroke="currentColor" stroke-width="1.7"></circle>
          <circle cx="16.6" cy="7.4" r="1.1" fill="currentColor"></circle>
        </svg>
      </a>
    </div>
  </div>
</footer>

<button class="to-top" aria-label="Back to top">
  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12 19V6M6 11l6-6 6 6"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
</button>

<script>
  // Back-to-top: appears after 600px of scroll (was duplicated per page).
  const tt = document.querySelector<HTMLButtonElement>('.to-top');
  if (tt) {
    window.addEventListener(
      'scroll',
      () => tt.classList.toggle('show', window.pageYOffset > 600),
      { passive: true }
    );
    tt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>
