---
/**
 * Calculators hub - /calculators
 * Financial-calculator card grid with on-brand dark hero. Pixel parity with
 * legacy calculators/index.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import { calculators, calcHref } from '../data/calculators';

const seo = {
  title: 'Calculators',
  description:
    'Free financial calculators from Shriram - SIP, lumpsum, SWP, fixed deposit and NPS. Plan investments and estimate returns instantly, no sign-up.',
  path: '/calculators',
};

// Calculator cards come from the single source of truth (src/data/calculators.ts).
const CALCS = calculators;
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <Hero breadcrumb={[{ name: 'Calculators' }]} id="sec-hero" dataSection="hero">
    <Fragment slot="title">The Calculators You Need, <span class="g">All in One Place.</span></Fragment>
    <Fragment slot="lead">
      Plan investments, estimate returns, optimise taxes, and map your retirement - all the
      financial tools you need, free and instant.
    </Fragment>
  </Hero>

  <!-- ================= CALCULATORS ================= -->
  <section class="section stack" id="sec-calculators" data-section="calculators" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Explore Our Calculators</h2>
      <p class="sec-lead">
        Pick a tool and get instant, accurate projections to plan every part of your financial
        journey.
      </p>
    </div>
    <div class="calc-grid" data-reveal-row>
      {
        CALCS.map((c) => (
          <a class="calc-card" href={calcHref(c.slug)}>
            <span class="cc-title">{c.title}</span>
            <span class="cc-desc">{c.desc}</span>
            <span class="cc-cta">Calculate Now <span class="arr" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></span>
          </a>
        ))
      }
      <div class="calc-card cta-tile">
        <span class="cc-title">Open a Demat Account</span>
        <span class="cc-desc">
          Like what you see? Start investing in under 5 minutes - zero paperwork.
        </span>
        <a class="btn btn-primary" href="/open-demat-account">Open Demat Account</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ================= Calculators page ================= */
  /* Calculators-HUB hero is the standard global <Hero> template (Type 1, rule 7/18):
     dark V4 surface, texture, tall band, breadcrumb and the 8px bottom stroke - identical
     to the product pages (only the trust chips are omitted). */

  /* calculator cards grid */
  .calc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .calc-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    color: inherit;
    transition: border-color 0.22s ease;
  }
  @media (min-width: 1024px) and (hover: hover) {
    /* minimal hover: crisp olive border + arrow nudge (no shadow / lift) */
  a.calc-card:hover {
    border-color: var(--color-olive-950);
  }
  }
  .cc-title {
    font-weight: 500;
    font-size: 20px;
    color: var(--color-text-primary);
  }
  .cc-desc {
    flex: 1 1 auto;
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-muted);
  }
  .cc-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text-heading-dark);
    font-weight: 600;
    font-size: 16px;
  }
  .cc-cta .arr {
    display: inline-flex;
    transition: transform 0.25s ease;
  }
  .cc-cta .arr svg {
    display: block;
    width: 16px;
    height: 16px;
  }
  @media (min-width: 1024px) and (hover: hover) {
    a.calc-card:hover .cc-cta .arr {
    transform: translateX(5px);
  }
  }

  /* demat CTA tile (fills the 6th grid cell) */
  .cta-tile {
    background: var(--color-olive-950);
    border-color: var(--color-olive-950);
  }
  .cta-tile .cc-title {
    color: var(--color-white);
  }
  .cta-tile .cc-desc {
    color: var(--color-sage-200);
  }
  .cta-tile .btn-primary {
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .calc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .calc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
