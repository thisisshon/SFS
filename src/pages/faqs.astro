---
/**
 * FAQs - /faqs
 * A single help hub with three layers, all in-page (no reloads):
 *   1. FAQ Assistant - a strictly-scoped, retrieval-only helper. Its ENTIRE
 *      knowledge is the FAQ corpus in src/data/faqs.ts; it has no model and no
 *      external source, so it cannot answer anything not grounded in that file.
 *   2. Browse - category -> product -> questions drill-down.
 *   3. Every product's accordion (rendered once, toggled by the drill-down) also
 *      feeds the FAQPage JSON-LD, so markup + schema + assistant never drift.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema } from '../lib/seo';
import { faqCategories, allFaqEntries, faqCount } from '../data/faqs';

const site = Astro.site!.href;

const seo = {
  title: 'FAQs - Answers on Every Product',
  description: `Browse ${faqCount}+ frequently asked questions across Shriram's trading, investing, new-issue and loan-against-securities products, or ask our on-page FAQ assistant.`,
  path: '/faqs',
  jsonLd: [
    faqPageSchema(allFaqEntries),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'FAQs', path: '/faqs' },
      ],
      site
    ),
  ],
};

// Category icons - real inline SVGs (rule 4), rendered at 32px on the card.
const ICONS: Record<string, string> = {
  trading: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><rect x="5" y="10" width="3" height="7" rx="1"/><path d="M6.5 10V7.5M6.5 19.5V17"/><rect x="11" y="6" width="3" height="11" rx="1"/><path d="M12.5 6V4M12.5 19v-2"/><rect x="17" y="12" width="3" height="5" rx="1"/><path d="M18.5 12v-2M18.5 19v-2"/></svg>`,
  investing: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l5-5 3.5 3.5L20 8"/><path d="M15 8h5v5"/><path d="M3 21h18"/></svg>`,
  newissues: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c2.8 1.4 4.5 4.3 4.5 7.5 0 2-.7 3.6-1.6 4.9H9.1C8.2 14.1 7.5 12.5 7.5 10.5 7.5 7.3 9.2 4.4 12 3Z"/><circle cx="12" cy="9.5" r="1.6"/><path d="M9.1 15.4 7 17.5M14.9 15.4 17 17.5M10 18.5c0 1.5 1 2.5 2 2.5s2-1 2-2.5"/></svg>`,
  loans: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="8.5" r="4.5"/><path d="M8.5 6.5v4M6.9 7.4a1.6 1.6 0 0 1 3 0M6.6 9.6a1.6 1.6 0 0 0 3 0"/><path d="M13 12.2c2.7.2 4.8 1.2 4.8 2.4 0 .8-1 1.5-2.4 1.9M20 15.5v3.6c0 1.3-2.5 2.4-5.5 2.4S9 20.4 9 19.1v-2.2"/></svg>`,
};

const UI = {
  arrow: `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10M11 6l4 4-4 4"/></svg>`,
  chevron: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>`,
  sparkle: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.8 4.6L18.4 9l-4.6 1.4L12 15l-1.8-4.6L5.6 9l4.6-1.4L12 3Z"/><path d="M18.5 15l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7.7-1.8Z"/></svg>`,
  search: `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="6"/><path d="M17 17l-3.5-3.5"/></svg>`,
  send: `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h11M10 5l5 5-5 5"/></svg>`,
};

// Flattened corpus for the assistant (client-side retrieval index).
const searchDocs = faqCategories.flatMap((c) =>
  c.products.flatMap((p) =>
    p.faqs.map((f) => ({
      cat: c.id,
      catName: c.name,
      slug: p.slug,
      product: p.name,
      href: p.href,
      q: f.q,
      a: f.a,
    }))
  )
);

// Compact catalog for meta-intents (list products) + slug -> category lookup.
const catalog = faqCategories.map((c) => ({
  id: c.id,
  name: c.name,
  products: c.products.map((p) => ({ slug: p.slug, name: p.name, href: p.href })),
}));

const totalProducts = faqCategories.reduce((n, c) => n + c.products.length, 0);
const catCount = (c: (typeof faqCategories)[number]) =>
  c.products.reduce((n, p) => n + p.faqs.length, 0);

// A handful of good starter questions for the assistant.
const starters = [
  'How do I open a Demat account?',
  'How are equity gains taxed?',
  'What is the difference between SIP and lump sum?',
  'What is the extra tax benefit in NPS?',
  'How does a loan against shares work?',
];
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <Hero breadcrumb={[{ name: 'FAQs' }]}>
    <Fragment slot="eyebrow">Help Centre</Fragment>
    <Fragment slot="title">Frequently Asked <span class="g">Questions</span></Fragment>
    <Fragment slot="lead">
      {faqCount}+ clear answers across all {totalProducts} products. Ask the FAQ assistant, or browse
      by category and product below.
    </Fragment>
  </Hero>

  <!-- ============ 1 · FAQ ASSISTANT ============ -->
  <section class="section stack sec-tint" id="sec-ask" data-section="ask">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Ask the FAQ assistant</h2>
      <p class="sec-lead">
        Type a question in your own words. The assistant answers only from the FAQs on this page - it
        has no other source, so it will politely decline anything outside Shriram's products.
      </p>
    </div>

    <div class="aiq" id="aiq">
      <div class="aiq-head">
        <span class="aiq-badge" aria-hidden="true" set:html={UI.sparkle} />
        <div class="aiq-head-tx">
          <span class="aiq-name">FAQ Assistant</span>
          <span class="aiq-scope">Grounded only in {faqCount} product FAQs</span>
        </div>
        <button type="button" class="aiq-clear" id="aiq-clear" hidden>Clear</button>
      </div>

      <div class="aiq-log" id="aiq-log" role="log" aria-live="polite" aria-label="Assistant conversation">
        <div class="aiq-msg aiq-bot aiq-intro">
          <span class="aiq-av" aria-hidden="true" set:html={UI.sparkle} />
          <div class="aiq-bubble">
            <p>Hi! Ask me anything about Shriram's products - trading, investing, IPOs, NPS, loans against securities and more. I only answer from our FAQs.</p>
          </div>
        </div>
      </div>

      <div class="aiq-suggest" id="aiq-suggest" aria-label="Suggested questions">
        {starters.map((s) => <button type="button" class="aiq-chip" data-ask={s}>{s}</button>)}
      </div>

      <form class="aiq-form" id="aiq-form" autocomplete="off">
        <span class="aiq-in-ic" aria-hidden="true" set:html={UI.search} />
        <input
          class="aiq-input"
          id="aiq-input"
          type="text"
          name="q"
          placeholder="e.g. How are mutual funds taxed?"
          aria-label="Ask a question about our products"
          maxlength="200"
        />
        <button type="submit" class="btn btn-primary btn-xl aiq-send" id="aiq-send" aria-label="Ask">
          <span class="aiq-send-lb">Ask</span>
          <span class="btn-ico aiq-send-ic" aria-hidden="true" set:html={UI.send} />
        </button>
      </form>

      <p class="aiq-disc">
        Answers are drawn verbatim from the FAQs below and are for general information only - not
        investment advice. Investments in securities are subject to market risks.
      </p>
    </div>
  </section>

  <!-- ============ 2 · BROWSE (category -> product -> questions) ============ -->
  <section class="section stack sec-light" id="sec-browse" data-section="browse">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Got Questions?</h2>
      <p class="sec-lead">
        Pick a category to see its products, then open any product for its full set of answers.
      </p>
    </div>

    <div class="faqx" id="faqx">
      <nav class="faqx-bar" id="faqx-bar" aria-label="Browse path"></nav>

      <!-- LEVEL 0 · categories -->
      <div class="faqx-panel faqx-cats" data-level="cats">
        {
          faqCategories.map((c) => (
            <button type="button" class="faqx-cat" data-cat={c.id}>
              <span class="faqx-cat-ic" aria-hidden="true" set:html={ICONS[c.icon]} />
              <span class="faqx-cat-tx">
                <span class="faqx-cat-nm">{c.name}</span>
                <span class="faqx-cat-tg">{c.tagline}</span>
              </span>
              <span class="faqx-cat-meta">
                <span class="faqx-count">{c.products.length} products · {catCount(c)} FAQs</span>
                <span class="faqx-go" aria-hidden="true" set:html={UI.arrow} />
              </span>
            </button>
          ))
        }
      </div>

      <!-- LEVEL 1 · products per category -->
      {
        faqCategories.map((c) => (
          <div class="faqx-panel faqx-prods" data-cat={c.id} hidden>
            <div class="faqx-grid">
              {c.products.map((p) => (
                <button type="button" class="faqx-prod" data-cat={c.id} data-prod={p.slug}>
                  <span class="faqx-prod-nm">{p.name}</span>
                  <span class="faqx-prod-bl">{p.blurb}</span>
                  <span class="faqx-prod-meta">
                    <span class="faqx-count">{p.faqs.length} questions</span>
                    <span class="faqx-go" aria-hidden="true" set:html={UI.arrow} />
                  </span>
                </button>
              ))}
            </div>
          </div>
        ))
      }

      <!-- LEVEL 2 · questions per product -->
      {
        faqCategories.flatMap((c) =>
          c.products.map((p) => (
            <div class="faqx-panel faqx-faq" data-cat={c.id} data-prod={p.slug} hidden>
              <div class="faqx-faq-head">
                <div class="faqx-faq-htx">
                  <h3 class="faqx-faq-tt">{p.name}</h3>
                  <p class="faqx-faq-sb">{p.faqs.length} frequently asked questions</p>
                </div>
                <a class="btn btn-secondary btn-md" href={p.href}>
                  Visit {p.name} page
                </a>
              </div>
              <div class="faqx-acc">
                <FaqAccordion faqs={p.faqs} />
              </div>
            </div>
          ))
        )
      }
    </div>
  </section>

  <!-- ============ 3 · CTA ============ -->
  <section class="cta-sec section sec-tint" id="sec-cta" data-section="cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Still Have A Question?</h3>
        <p class="ct-sub">Our team is a call away for anything the FAQs don't cover.</p>
      </div>
      <a class="btn btn-primary btn-xl" href="/contact-us">Talk To Us</a>
    </div>
  </section>

  <!-- data for the client-side assistant (its entire knowledge base) -->
  <script type="application/json" id="faqx-search" set:html={JSON.stringify(searchDocs)} is:inline />
  <script type="application/json" id="faqx-catalog" set:html={JSON.stringify(catalog)} is:inline />
</BaseLayout>

<style is:global>
  /* ===================================================================
     /faqs page - assistant (.aiq) + drill-down browser (.faqx).
     is:global because the assistant injects message/chip nodes at runtime
     (scoped styles would not reach them). All selectors are namespaced.
     Tokens only; hover gated to desktop (rule 15); 48px tap targets (rule 14).
     =================================================================== */

  /* ---------- Assistant ---------- */
  .aiq {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-3xl);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: var(--shadow-glass);
  }
  .aiq-head { display: flex; align-items: center; gap: 16px; }
  .aiq-badge {
    width: 48px; height: 48px; flex: none; border-radius: var(--radius-full);
    display: grid; place-items: center;
    background: var(--color-action-primary); color: var(--color-action-primary-ink);
  }
  .aiq-badge svg { width: 24px; height: 24px; }
  .aiq-head-tx { display: flex; flex-direction: column; gap: 4px; flex: 1 0 0; min-width: 0; }
  .aiq-name { font-weight: 600; font-size: 18px; color: var(--color-text-heading-dark); }
  .aiq-scope { font-weight: 400; font-size: 12px; color: var(--color-text-tertiary); }
  .aiq-clear {
    -webkit-appearance: none; appearance: none; background: transparent;
    border: 1px solid var(--color-border-divider); border-radius: var(--radius-full);
    color: var(--color-text-secondary); font-family: inherit; font-size: 12px; font-weight: 500;
    min-height: 40px; padding: 0 16px; cursor: pointer;
    transition: border-color .18s var(--ease-standard), color .18s var(--ease-standard);
  }

  .aiq-log {
    display: flex; flex-direction: column; gap: 16px;
    max-height: 460px; overflow-y: auto; scroll-behavior: smooth;
    padding-right: 4px;
  }
  .aiq-msg { display: flex; gap: 12px; align-items: flex-start; max-width: 100%; }
  .aiq-msg.aiq-user { flex-direction: row-reverse; }
  .aiq-av {
    width: 32px; height: 32px; flex: none; border-radius: var(--radius-full);
    display: grid; place-items: center;
    background: var(--color-action-primary); color: var(--color-action-primary-ink);
  }
  .aiq-av svg { width: 20px; height: 20px; }
  .aiq-bubble {
    background: var(--color-surface-section-tint);
    border-radius: var(--radius-xl);
    border-top-left-radius: var(--radius-xs);
    padding: 16px 20px; max-width: 640px;
    animation: aiq-pop .28s var(--ease-standard) both;
  }
  .aiq-user .aiq-bubble {
    background: var(--color-action-dark); color: var(--color-text-on-dark);
    border-top-left-radius: var(--radius-xl); border-top-right-radius: var(--radius-xs);
  }
  .aiq-bubble p { font-weight: 400; font-size: 16px; line-height: 1.5; color: var(--color-text-primary); }
  .aiq-user .aiq-bubble p { color: var(--color-text-on-dark); }
  .aiq-bubble p + p { margin-top: 8px; }

  /* answer meta: which FAQ the answer came from */
  .aiq-from {
    display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px;
    font-size: 12px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase;
    color: var(--color-action-primary-ink);
    background: var(--color-action-primary); border-radius: var(--radius-full);
    padding: 4px 12px;
  }
  .aiq-ansq { font-weight: 600; font-size: 16px; color: var(--color-text-heading-dark); margin-bottom: 8px; }

  /* actions under an answer */
  .aiq-acts { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .aiq-act {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit;
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--color-surface-card); border: 1px solid var(--color-border-divider);
    border-radius: var(--radius-full); color: var(--color-text-secondary);
    font-size: 14px; font-weight: 500; min-height: 40px; padding: 0 16px;
    text-decoration: none;
    transition: border-color .18s var(--ease-standard), color .18s var(--ease-standard), background-color .18s var(--ease-standard);
  }
  .aiq-act svg { width: 16px; height: 16px; }
  .aiq-related { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .aiq-related-lb { font-size: 12px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: var(--color-text-tertiary); }
  .aiq-related-row { display: flex; flex-direction: column; gap: 8px; }
  .aiq-rel {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit;
    text-align: left; background: var(--color-surface-card);
    border: 1px solid var(--color-border-divider); border-radius: var(--radius-md);
    color: var(--color-link); font-size: 14px; font-weight: 500; padding: 12px 16px;
    display: flex; align-items: center; gap: 8px; min-height: 48px;
    transition: border-color .18s var(--ease-standard), background-color .18s var(--ease-standard);
  }
  .aiq-rel::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--color-action-primary); flex: none; }

  /* typing dots */
  .aiq-typing { display: inline-flex; gap: 8px; padding: 4px 0; }
  .aiq-typing span { width: 8px; height: 8px; border-radius: 50%; background: var(--color-text-tertiary); animation: aiq-blink 1.2s infinite ease-in-out both; }
  .aiq-typing span:nth-child(2) { animation-delay: .18s; }
  .aiq-typing span:nth-child(3) { animation-delay: .36s; }

  /* suggested starter chips */
  .aiq-suggest { display: flex; flex-wrap: wrap; gap: 8px; }
  .aiq-chip {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit;
    background: var(--color-surface-section-light); border: 1px solid var(--color-border-divider);
    border-radius: var(--radius-full); color: var(--color-text-secondary);
    font-size: 14px; font-weight: 500; min-height: 40px; padding: 0 16px;
    transition: border-color .18s var(--ease-standard), color .18s var(--ease-standard), background-color .18s var(--ease-standard);
  }

  /* input row - a search field (radius/border per the field convention) + the
     global .btn primary send button (rule 8 field language, rule 17 buttons). */
  .aiq-form { display: flex; align-items: center; gap: 12px; position: relative; }
  .aiq-in-ic { position: absolute; left: 16px; width: 20px; height: 20px; color: var(--color-text-tertiary); pointer-events: none; }
  .aiq-input {
    flex: 1 0 0; min-width: 0; height: 48px; box-sizing: border-box;
    border: 1px solid var(--color-field-border, var(--color-border-card));
    border-radius: var(--radius-md); background: var(--color-surface-page);
    padding: 0 16px 0 44px; font-family: inherit; font-size: 16px; color: var(--color-text-primary);
    transition: border-color .18s var(--ease-standard), box-shadow .18s var(--ease-standard);
  }
  .aiq-input::placeholder { color: var(--color-text-faint); }
  .aiq-input:focus-visible {
    outline: none;
    border-color: var(--color-field-border-active, var(--color-action-primary));
    box-shadow: var(--shadow-ring-gold);
  }
  /* the send button is .btn .btn-primary - only layout overrides live here */
  .aiq-send { min-width: 0; padding-inline: 24px; }
  .aiq-send-ic { display: none; }
  .aiq-disc { font-size: 12px; line-height: 1.5; color: var(--color-text-tertiary); }

  /* ---------- Browse drill-down ---------- */
  .faqx { display: flex; flex-direction: column; gap: 24px; }

  .faqx-bar { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; min-height: 40px; }
  .faqx-crumb {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit;
    background: transparent; border: 0; padding: 8px 4px; min-height: 40px;
    font-size: 14px; font-weight: 500; color: var(--color-link);
    display: inline-flex; align-items: center; gap: 4px;
    transition: color .18s var(--ease-standard);
  }
  .faqx-crumb[aria-current="page"] { color: var(--color-text-tertiary); cursor: default; font-weight: 500; }
  .faqx-sep { width: 16px; height: 16px; color: var(--color-text-faint); display: inline-flex; }
  .faqx-sep svg { width: 16px; height: 16px; }

  .faqx-panel { animation: aiq-rise .34s var(--ease-standard) both; }

  .faqx-cats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .faqx-cat {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit; text-align: left;
    display: flex; align-items: center; gap: 20px;
    background: var(--color-surface-card); border: 1px solid var(--color-border-card);
    border-radius: var(--radius-3xl); padding: 28px; min-height: 48px;
    transition: border-color .2s var(--ease-standard), transform .2s var(--ease-standard), box-shadow .2s var(--ease-standard);
  }
  .faqx-cat-ic {
    width: 64px; height: 64px; flex: none; border-radius: var(--radius-xl);
    display: grid; place-items: center;
    background: var(--color-surface-section-tint); color: var(--color-text-heading-dark);
  }
  .faqx-cat-ic svg { width: 32px; height: 32px; }
  .faqx-cat-tx { display: flex; flex-direction: column; gap: 8px; flex: 1 0 0; min-width: 0; }
  .faqx-cat-nm { font-weight: 600; font-size: 20px; color: var(--color-text-heading-dark); }
  .faqx-cat-tg { font-weight: 400; font-size: 14px; line-height: 1.5; color: var(--color-text-secondary); }
  .faqx-cat-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 12px; flex: none; }
  .faqx-count { font-size: 12px; font-weight: 500; color: var(--color-text-tertiary); white-space: nowrap; }
  .faqx-go {
    width: 40px; height: 40px; border-radius: var(--radius-full); flex: none;
    display: grid; place-items: center;
    background: var(--color-surface-section-tint); color: var(--color-text-heading-dark);
    transition: background-color .2s var(--ease-standard), color .2s var(--ease-standard), transform .2s var(--ease-standard);
  }
  .faqx-go svg { width: 20px; height: 20px; }

  .faqx-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .faqx-prod {
    -webkit-appearance: none; appearance: none; cursor: pointer; font-family: inherit; text-align: left;
    display: flex; flex-direction: column; gap: 12px;
    background: var(--color-surface-card); border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg); padding: 24px; min-height: 48px;
    transition: border-color .2s var(--ease-standard), transform .2s var(--ease-standard), box-shadow .2s var(--ease-standard);
  }
  .faqx-prod-nm { font-weight: 600; font-size: 18px; color: var(--color-text-heading-dark); }
  .faqx-prod-bl { font-weight: 400; font-size: 14px; line-height: 1.5; color: var(--color-text-secondary); flex: 1 0 0; }
  .faqx-prod-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 4px; }

  .faqx-faq-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 24px; }
  .faqx-faq-htx { display: flex; flex-direction: column; gap: 8px; }
  .faqx-faq-tt { font-weight: 600; font-size: 28px; color: var(--color-text-heading-dark); }
  .faqx-faq-sb { font-weight: 400; font-size: 14px; color: var(--color-text-tertiary); }
  /* accordion segment fill against the light band (matches the sanctioned sec-light look) */
  .faqx-acc { --faq-item-bg: var(--color-cream-400); }

  @keyframes aiq-pop { from { opacity: 0; transform: translateY(8px) scale(.99); } to { opacity: 1; transform: none; } }
  @keyframes aiq-rise { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @keyframes aiq-blink { 0%, 80%, 100% { opacity: .25; } 40% { opacity: 1; } }

  /* ---------- hover (desktop only, rule 15) ---------- */
  @media (min-width: 1024px) and (hover: hover) {
    .aiq-chip:hover, .aiq-act:hover { border-color: var(--color-action-primary); color: var(--color-text-primary); }
    .aiq-rel:hover { border-color: var(--color-action-primary); background: var(--color-surface-section-light); }
    .aiq-clear:hover { border-color: var(--color-action-dark); color: var(--color-text-primary); }
    .faqx-crumb:not([aria-current="page"]):hover { color: var(--color-link-hover); text-decoration: underline; }
    .faqx-cat:hover, .faqx-prod:hover { border-color: var(--color-action-primary); transform: translateY(-4px); box-shadow: var(--shadow-control); }
    .faqx-cat:hover .faqx-go, .faqx-prod:hover .faqx-go { background: var(--color-action-primary); color: var(--color-action-primary-ink); }
  }

  /* ---------- responsive ---------- */
  @media (max-width: 900px) {
    .faqx-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .aiq { padding: 20px; }
    .faqx-cats { grid-template-columns: 1fr; }
    .faqx-grid { grid-template-columns: 1fr; }
    .faqx-cat { padding: 20px; gap: 16px; }
    .faqx-cat-ic { width: 52px; height: 52px; }
    .faqx-cat-ic svg { width: 24px; height: 24px; }
    .faqx-cat-meta { align-self: stretch; flex-direction: row; align-items: center; justify-content: space-between; }
    .faqx-faq-head { flex-direction: column; align-items: flex-start; }
    /* rule 14 - 48px tap targets on touch */
    .aiq-chip, .aiq-act, .aiq-clear, .faqx-crumb { min-height: 48px; }
    .aiq-send-lb { display: none; }
    .aiq-send-ic { display: inline-flex; }
    .aiq-send { padding-inline: 0; width: 48px; }
    .aiq-bubble { max-width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .aiq-bubble, .faqx-panel { animation: none; }
    .aiq-typing span { animation: none; }
  }
</style>

<script>
  // ===================================================================
  // FAQ page client: (A) the drill-down browser, (B) the retrieval-only
  // assistant. The assistant's knowledge is ONLY the embedded FAQ corpus -
  // no model, no network, no external source - so it is structurally unable
  // to answer anything not grounded in the FAQs.
  // ===================================================================
  type Doc = { cat: string; catName: string; slug: string; product: string; href: string; q: string; a: string };
  type Cat = { id: string; name: string; products: { slug: string; name: string; href: string }[] };

  const DOCS: Doc[] = JSON.parse(document.getElementById('faqx-search')!.textContent || '[]');
  const CATALOG: Cat[] = JSON.parse(document.getElementById('faqx-catalog')!.textContent || '[]');
  const slugToCat = new Map<string, string>();
  CATALOG.forEach((c) => c.products.forEach((p) => slugToCat.set(p.slug, c.id)));

  /* ---------------- (A) Drill-down browser ---------------- */
  const faqx = document.getElementById('faqx');
  if (faqx) {
    const bar = document.getElementById('faqx-bar')!;
    const panels = Array.from(faqx.querySelectorAll<HTMLElement>('.faqx-panel'));
    const show = (el: HTMLElement | null | undefined) => {
      panels.forEach((p) => (p.hidden = true));
      if (el) {
        el.hidden = false;
        // retrigger the entrance animation
        el.style.animation = 'none';
        void el.offsetWidth;
        el.style.animation = '';
      }
    };
    const prodName = (slug: string) =>
      CATALOG.flatMap((c) => c.products).find((p) => p.slug === slug)?.name || slug;
    const catName = (id: string) => CATALOG.find((c) => c.id === id)?.name || id;

    const crumb = (label: string, onClick: (() => void) | null) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'faqx-crumb';
      b.textContent = label;
      if (onClick) b.addEventListener('click', onClick);
      else b.setAttribute('aria-current', 'page');
      return b;
    };
    const sep = () => {
      const s = document.createElement('span');
      s.className = 'faqx-sep';
      s.setAttribute('aria-hidden', 'true');
      s.innerHTML =
        '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>';
      return s;
    };

    const toCats = () => {
      bar.replaceChildren(crumb('All topics', null));
      show(faqx.querySelector<HTMLElement>('.faqx-cats'));
    };
    const toProds = (cat: string) => {
      bar.replaceChildren(crumb('All topics', toCats), sep(), crumb(catName(cat), null));
      show(faqx.querySelector<HTMLElement>(`.faqx-prods[data-cat="${cat}"]`));
    };
    const toFaqs = (cat: string, slug: string) => {
      bar.replaceChildren(
        crumb('All topics', toCats),
        sep(),
        crumb(catName(cat), () => toProds(cat)),
        sep(),
        crumb(prodName(slug), null)
      );
      show(faqx.querySelector<HTMLElement>(`.faqx-faq[data-prod="${slug}"]`));
    };

    faqx.querySelectorAll<HTMLButtonElement>('.faqx-cat').forEach((b) =>
      b.addEventListener('click', () => toProds(b.dataset.cat!))
    );
    faqx.querySelectorAll<HTMLButtonElement>('.faqx-prod').forEach((b) =>
      b.addEventListener('click', () => toFaqs(b.dataset.cat!, b.dataset.prod!))
    );

    toCats();

    // exposed so the assistant can deep-link into a product's questions
    (window as any).faqxOpen = (slug: string) => {
      const cat = slugToCat.get(slug);
      if (!cat) return;
      toFaqs(cat, slug);
      document.getElementById('sec-browse')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };
  }

  /* ---------------- (B) Retrieval-only assistant ---------------- */
  const STOP = new Set(
    'a an the is are was were be been being do does did to of in on at for and or but if it its as with without into out up down about over under from this that these those there here they them their you your our we he she his her my me i what how why when where which who whom whose whether will would shall should can could may might not no nor only just also very more most than then so such per vs versus each any all some other into onto within'.split(
      ' '
    )
  );
  const stem = (w: string): string => {
    if (w.length <= 3) return w;
    return w
      .replace(/ies$/, 'y')
      .replace(/(ches|shes|sses|xes|zes)$/, '')
      .replace(/ing$/, '')
      .replace(/ed$/, '')
      .replace(/s$/, '');
  };
  const tokenize = (s: string): string[] =>
    (s.toLowerCase().match(/[a-z0-9&%]+/g) || [])
      .filter((w) => !STOP.has(w) && w.length > 1)
      .map(stem)
      .filter((w) => w.length > 1);

  // finance-term synonym expansion (keys/values are stemmed at build of the query)
  const SYN: Record<string, string[]> = {
    tax: ['taxation', 'ltcg', 'stcg', 'capital', 'gain', 'tds'],
    charge: ['fee', 'cost', 'brokerage', 'commission', 'expense', 'price'],
    fee: ['charge', 'cost', 'brokerage'],
    cost: ['charge', 'fee', 'brokerage'],
    open: ['start', 'begin', 'create'],
    start: ['open', 'begin', 'invest'],
    account: ['demat', 'trading'],
    demat: ['account', 'depository'],
    sip: ['systematic', 'monthly', 'installment'],
    lumpsum: ['lump', 'onetime'],
    risk: ['risky', 'safe', 'safety', 'volatile'],
    return: ['profit', 'gain', 'yield', 'growth'],
    withdraw: ['redeem', 'exit', 'redemption', 'sell'],
    loan: ['borrow', 'credit', 'pledge', 'overdraft'],
    pledge: ['lien', 'collateral', 'loan'],
    fund: ['mutual', 'scheme', 'nav'],
    kid: ['minor', 'child', 'children'],
    minimum: ['least', 'lowest', 'smallest'],
    hour: ['time', 'timing', 'session', 'clock'],
    eligible: ['eligibility', 'qualify', 'allowed', 'who'],
    us: ['usa', 'america', 'foreign', 'global', 'overseas'],
    retire: ['retirement', 'pension', 'nps'],
  };
  // ---- build BM25 index over the corpus ----
  type IDoc = { d: Doc; tf: Record<string, number>; len: number; nameSet: Set<string> };
  // titleVocab = terms that appear in a QUESTION, product or category name (the
  // "topical" fields). A word found only in an answer body (e.g. "weather" in a
  // commodities answer) is NOT topical, so it can never make an off-topic query
  // look on-topic. This is the backbone of the scope guard.
  const titleVocab = new Set<string>();
  const idocs: IDoc[] = DOCS.map((d) => {
    const qt = tokenize(d.q);
    const at = tokenize(d.a);
    const nt = tokenize(d.product);
    const ct = tokenize(d.catName);
    [...qt, ...nt, ...ct].forEach((t) => titleVocab.add(t));
    // question + product name weigh most (that is what the user usually names)
    const bag = [...qt, ...qt, ...qt, ...nt, ...nt, ...ct, ...at];
    const tf: Record<string, number> = {};
    bag.forEach((t) => (tf[t] = (tf[t] || 0) + 1));
    return { d, tf, len: bag.length, nameSet: new Set([...nt, ...ct]) };
  });
  const N = idocs.length;
  const df: Record<string, number> = {};
  idocs.forEach((x) => Object.keys(x.tf).forEach((t) => (df[t] = (df[t] || 0) + 1)));
  const idf: Record<string, number> = {};
  Object.keys(df).forEach((t) => (idf[t] = Math.log(1 + (N - df[t] + 0.5) / (df[t] + 0.5))));
  const vocab = new Set(Object.keys(df));
  const avgdl = idocs.reduce((s, x) => s + x.len, 0) / Math.max(1, N);
  const K = 1.5;
  const B = 0.75;

  const EXP_W = 0.32; // expansion terms count for less than the user's own words
  const NAME_BOOST = 2.4; // reward docs whose product/category the query names
  type Ranked = { d: Doc; s: number };
  const rank = (q: string) => {
    const base = tokenize(q);
    const baseSet = new Set(base);
    const known = base.filter((t) => vocab.has(t));
    const knownTopical = base.filter((t) => titleVocab.has(t));
    // expansions, excluding any term the user already typed
    const expSet = new Set<string>();
    base.forEach((t) =>
      (SYN[t] || []).forEach((s) => {
        const st = stem(s);
        if (!baseSet.has(st)) expSet.add(st);
        if (titleVocab.has(st)) knownTopical.push(st);
      })
    );
    const bm = (f: number, len: number) => (f * (K + 1)) / (f + K * (1 - B + (B * len) / avgdl));
    const ranked: Ranked[] = idocs
      .map((x) => {
        let s = 0;
        baseSet.forEach((t) => {
          const f = x.tf[t];
          if (f) s += (idf[t] || 0) * bm(f, x.len);
        });
        expSet.forEach((t) => {
          const f = x.tf[t];
          if (f) s += (idf[t] || 0) * bm(f, x.len) * EXP_W;
        });
        let hits = 0;
        baseSet.forEach((t) => {
          if (x.nameSet.has(t)) hits++;
        });
        if (hits) s += hits * NAME_BOOST;
        return { d: x.d, s };
      })
      .sort((a, b) => b.s - a.s);
    return { known, knownTopical, base, ranked };
  };

  // ---- conversational intents (all scoped to the FAQ system) ----
  const isGreeting = (q: string) => /^(hi|hii|hey|hello|yo|namaste|hola|good\s+(morning|afternoon|evening))\b/i.test(q.trim());
  const isThanks = (q: string) => /\b(thanks|thank you|thankyou|thx|ty|cheers|great|helpful)\b/i.test(q.trim()) && q.trim().split(/\s+/).length <= 4;
  const isCatalogAsk = (q: string) =>
    /(what|which|list|show).*(product|topic|categor|cover|offer|help|ask|answer)/i.test(q) ||
    /^(what can you (do|answer|help)|help|options|menu)\b/i.test(q.trim());

  /* ---------------- assistant UI ---------------- */
  const log = document.getElementById('aiq-log') as HTMLElement | null;
  const form = document.getElementById('aiq-form') as HTMLFormElement | null;
  const input = document.getElementById('aiq-input') as HTMLInputElement | null;
  const suggest = document.getElementById('aiq-suggest') as HTMLElement | null;
  const clearBtn = document.getElementById('aiq-clear') as HTMLButtonElement | null;

  if (log && form && input) {
    const scrollDown = () => (log.scrollTop = log.scrollHeight);

    const addUser = (text: string) => {
      const wrap = document.createElement('div');
      wrap.className = 'aiq-msg aiq-user';
      wrap.innerHTML =
        '<span class="aiq-av" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.2"/><path d="M5.5 19c.7-3 3.3-4.6 6.5-4.6S17.8 16 18.5 19"/></svg></span>';
      const b = document.createElement('div');
      b.className = 'aiq-bubble';
      const p = document.createElement('p');
      p.textContent = text; // user text is never treated as HTML
      b.appendChild(p);
      wrap.appendChild(b);
      log.appendChild(wrap);
      scrollDown();
    };

    const botShell = () => {
      const wrap = document.createElement('div');
      wrap.className = 'aiq-msg aiq-bot';
      wrap.innerHTML =
        '<span class="aiq-av" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.8 4.6L18.4 9l-4.6 1.4L12 15l-1.8-4.6L5.6 9l4.6-1.4L12 3Z"/></svg></span>';
      const b = document.createElement('div');
      b.className = 'aiq-bubble';
      wrap.appendChild(b);
      log.appendChild(wrap);
      return b;
    };

    const typing = () => {
      const b = botShell();
      b.innerHTML = '<span class="aiq-typing"><span></span><span></span><span></span></span>';
      scrollDown();
      return b.parentElement as HTMLElement;
    };

    const askText = (t: string) => {
      input.value = t;
      form.requestSubmit();
    };

    // Render an answer into a bubble element.
    const renderAnswer = (bubble: HTMLElement, top: Ranked, related: Doc[]) => {
      bubble.replaceChildren();
      const from = document.createElement('span');
      from.className = 'aiq-from';
      from.textContent = top.d.product;
      bubble.appendChild(from);

      const qh = document.createElement('div');
      qh.className = 'aiq-ansq';
      qh.textContent = top.d.q;
      bubble.appendChild(qh);

      const p = document.createElement('p');
      p.textContent = top.d.a;
      bubble.appendChild(p);

      const acts = document.createElement('div');
      acts.className = 'aiq-acts';
      const browse = document.createElement('button');
      browse.type = 'button';
      browse.className = 'aiq-act';
      browse.innerHTML =
        '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4h12M2 8h12M2 12h8"/></svg> All ' + escapeAttr(top.d.product) + ' FAQs';
      browse.addEventListener('click', () => (window as any).faqxOpen?.(top.d.slug));
      acts.appendChild(browse);

      const link = document.createElement('a');
      link.className = 'aiq-act';
      link.href = top.d.href;
      link.innerHTML =
        'Visit product page <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h8M9 5l3 3-3 3"/></svg>';
      acts.appendChild(link);
      bubble.appendChild(acts);

      if (related.length) {
        const rel = document.createElement('div');
        rel.className = 'aiq-related';
        const lb = document.createElement('span');
        lb.className = 'aiq-related-lb';
        lb.textContent = 'Related questions';
        rel.appendChild(lb);
        const row = document.createElement('div');
        row.className = 'aiq-related-row';
        related.forEach((d) => {
          const r = document.createElement('button');
          r.type = 'button';
          r.className = 'aiq-rel';
          r.textContent = d.q;
          r.addEventListener('click', () => askText(d.q));
          row.appendChild(r);
        });
        rel.appendChild(row);
        bubble.appendChild(rel);
      }
      scrollDown();
    };

    const escapeAttr = (s: string) => s.replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c] as string));

    const renderText = (bubble: HTMLElement, paras: string[], chips?: string[]) => {
      bubble.replaceChildren();
      paras.forEach((t) => {
        const p = document.createElement('p');
        p.textContent = t;
        bubble.appendChild(p);
      });
      if (chips && chips.length) {
        const rel = document.createElement('div');
        rel.className = 'aiq-related';
        const row = document.createElement('div');
        row.className = 'aiq-related-row';
        chips.forEach((c) => {
          const r = document.createElement('button');
          r.type = 'button';
          r.className = 'aiq-rel';
          r.textContent = c;
          r.addEventListener('click', () => askText(c));
          row.appendChild(r);
        });
        rel.appendChild(row);
        bubble.appendChild(rel);
      }
      scrollDown();
    };

    const REFUSAL =
      "I can only answer questions about Shriram's products and the FAQs on this page. I don't have any other information. Try asking about equity, mutual funds, IPOs, NPS, loans against securities, and similar topics.";

    const catalogReply = (bubble: HTMLElement) => {
      const paras = ['I can answer questions about these products, drawn only from their FAQs:'];
      CATALOG.forEach((c) => paras.push(c.name + ': ' + c.products.map((p) => p.name).join(', ') + '.'));
      renderText(bubble, paras, [
        'How do I open a Demat account?',
        'How are equity gains taxed?',
        'What is the extra tax benefit in NPS?',
      ]);
    };

    // Core answer routine.
    const answer = (q: string) => {
      const shell = typing();
      const bubble = shell.querySelector('.aiq-bubble') as HTMLElement;
      window.setTimeout(() => {
        if (isGreeting(q)) {
          renderText(bubble, ["Hello! Ask me anything about Shriram's products and I'll answer from our FAQs."], [
            'What products can I ask about?',
          ]);
          return;
        }
        if (isThanks(q)) {
          renderText(bubble, ["You're welcome! Ask me anything else about our products."]);
          return;
        }
        if (isCatalogAsk(q)) {
          catalogReply(bubble);
          return;
        }

        const { knownTopical, ranked } = rank(q);
        const top = ranked[0];

        // Scope guard: the query must actually touch a product / question topic
        // (a word buried only in one answer body is not enough), AND the best
        // match must clear a floor. Otherwise the assistant declines - it never
        // reaches outside the FAQ corpus.
        const offTopic = knownTopical.length === 0 || !top || top.s < 2.2;
        if (offTopic) {
          renderText(bubble, [REFUSAL], [
            'What products can I ask about?',
            'How do I start investing?',
          ]);
          return;
        }

        // gather related: next-best, distinct questions, reasonably close in score
        const related: Doc[] = [];
        const seenQ = new Set([top.d.q]);
        for (let i = 1; i < ranked.length && related.length < 3; i++) {
          const r = ranked[i];
          if (r.s < top.s * 0.28 || r.s < 0.9) break;
          if (seenQ.has(r.d.q)) continue;
          seenQ.add(r.d.q);
          related.push(r.d);
        }
        renderAnswer(bubble, top, related);
      }, 420);
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      addUser(q);
      input.value = '';
      if (clearBtn) clearBtn.hidden = false;
      if (suggest) suggest.hidden = true;
      answer(q);
    });

    // starter + injected chips
    document.querySelectorAll<HTMLButtonElement>('.aiq-chip').forEach((c) =>
      c.addEventListener('click', () => askText(c.dataset.ask || c.textContent || ''))
    );

    clearBtn?.addEventListener('click', () => {
      // keep only the intro message
      Array.from(log.children).forEach((el, i) => {
        if (i > 0) el.remove();
      });
      if (suggest) suggest.hidden = false;
      clearBtn.hidden = true;
      input.focus();
    });
  }
</script>
