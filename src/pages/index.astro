---
/**
 * Homepage — /
 *
 * The ONLY page with the legacy `home.css` fork. This port dissolves the fork
 * into a scoped page <style> while preserving pixel parity:
 *   - Chrome (nav + mega-overlay) comes from BaseLayout (Header/MegaNav); the
 *     fork's `.ds-nav` / `.ds-mobile-menu` / `#nav-panel` markup + CSS + wiring
 *     scripts are dropped (byte-identical to shared — homepage-port-spec §1).
 *   - Footer is genuinely different from the shared one, so it stays page-local
 *     via footer="custom"; its alpha-whites are flattened to solid hex over the
 *     #0a0b07 footer bg (rule 5 — see the flatten table in the <style>).
 *   - Body/section bg keeps the fork's #fffcf3 (--color-surface-page-home) on a
 *     `.home` wrapper; the global body bg is untouched.
 *   - "Inter" font references become var(--font-sans) (Outfit) — rule 3.
 *   - Tailwind preflight / @property / @theme token block / scrollbar-hiding are
 *     dropped (Astro+Tailwind v4 + global.css provide those).
 *   - The visually-distinctive features (hero video wash, pinned "Why Shriram"
 *     scroll section, dark product-card reveal grid, Antara band) keep every
 *     gradient / animation / scroll value EXACT.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { organizationSchema, faqPageSchema } from '../lib/seo';

// Homepage FAQ — verbatim from the 7 <details> below, same order. Drives the
// FAQPage JSON-LD; the visible markup stays the native <details> list.
const FAQS = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat Account holds your financial shares, mutual funds, and bonds safely in an electronic format. It is mandatory for trading in the Indian stock market.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account completely eliminates the risk of theft, loss, or damage to physical paper certificates. It enables instant, one-click online buying and selling of shares, reduces paperwork, and ensures all your investments are visible in one secure place.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Shriram Securities charges a flat ₹20 per executed order for options trading. Use our Brokerage Calculator to estimate total costs including STT, GST, and exchange charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage is the small fee charged when you buy and sell a stock on the exact same day. Option brokerage is a fixed flat fee (like our standard ₹20 per order) charged for trading in options contracts, regardless of how big or small the transaction volume is.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, absolutely! Legally, you can open more than one Demat account in India, provided they are opened with different stockbrokers. However, you can only link one Demat account to your primary trading account at a time.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. When a new company lists on the share market, its digital shares must be deposited directly into an electronic account. Therefore, you must have an active Demat account to apply for and receive shares in an IPO.',
  },
];

const seo = {
  // Legacy <title> carried a duplicated site-name suffix — dropped (BaseLayout
  // appends the site name once).
  title: 'Online Stock Trading & Wealth Management | Shriram Financial Services',
  description:
    "Trade stocks, invest in mutual funds, and manage wealth with India's SEBI-registered advisor-led platform. Zero delivery brokerage. Open a free Demat account today.",
  path: '/',
  jsonLd: [
    organizationSchema(Astro.site!.href),
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
  ],
};
