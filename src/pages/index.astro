  /* Products — Figma "Product Card v7" Smart-Animate (node 904:9490).
     Idle: charcoal card. Hover: the charcoal overlay CONDENSES into the
     top-right arrow point, revealing the olive card; a gold circle + arrow
     scale in, the icon enlarges + brightens, content rises, "View More" fades
     in. One 0.9s slow ease-out on every layer together. */
  .product-link-2 {
    --pc-dur: 0.9s;
    --pc-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --pc-delay: 0s;
    position: relative;
    display: flex;
    height: 284px;
    flex-direction: column;
    overflow: hidden;
    border-radius: 24px;
    border: 1px solid #ffffff1a; /* Tier-2: rule-5 (alpha) — parity-preserved (card border on dark) */
    padding: 32px;
    background-color: #2e3914; /* --color-olive-900 (revealed base) */
  }
  .product-link-2:hover {
    --pc-delay: 0.1s;
    background-color: #2e3914; /* --color-olive-900 */
  }
  @media (hover: hover) {
    .product-link-2:hover {
      z-index: 10;
    }
  }
  .product-link-2::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #2b2c2b; /* charcoal overlay — page-local literal (Tier-2) */
    clip-path: circle(150% at calc(100% - 60px) 60px);
    transition: clip-path var(--pc-dur) var(--pc-ease);
  }
  .product-link-2:hover::before {
    clip-path: circle(0% at calc(100% - 60px) 60px);
  }
  .product-link-2:hover .product-box-6 {
    transform: translateY(-10px);
  }
  /* icon scales from its left edge — grows rightward, not from centre */
  .product-img {
    width: 44px; /* Tier-2: off-scale icon (parity) */
    height: 44px;
    flex-shrink: 0;
    object-fit: contain;
    color: #d7d7cd; /* page-local literal (Tier-2) */
    transform-origin: left center;
    transition: transform var(--pc-dur) var(--pc-ease), color var(--pc-dur) var(--pc-ease);
  }
  .product-img [stroke] {
    stroke: currentColor;
  }
  .product-link-2:hover .product-img {
    transform: scale(1.14);
    color: #ffffff;
  }
  .product-subtitle,
  .product-link-2:hover .product-subtitle {
    margin-top: 20px;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.5;
  }
  .product-text-2,
  .product-link-2:hover .product-text-2 {
    margin-top: 8px;
    font-size: 14px;
    line-height: 1.5;
  }
  /* View More: revealed via opacity+transform only (absolute, out of flow) so
     the centred text never reflows/jitters as it appears. */
  .product-label {
    display: block;
    position: absolute;
    left: 0;
    bottom: 0;
    margin-top: 0;
    max-height: none;
    overflow: visible;
    font-size: 12px;
    font-weight: 500;
    color: #fffc; /* Tier-2: rule-5 (alpha) — parity-preserved (#ffffffcc) */
    opacity: 0;
    transform: translateY(12px);
    transition: opacity var(--pc-dur) var(--pc-ease), transform var(--pc-dur) var(--pc-ease);
  }
  .product-link-2:hover .product-label {
    opacity: 1;
    transform: translateY(0);
    max-height: none;
    margin-top: 0;
  }
  .product-card-circle {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background-color: #f3b83f; /* --color-gold-400 */
    opacity: 0;
    transform: scale(0.4);
    transition: opacity var(--pc-dur) var(--pc-ease), transform var(--pc-dur) var(--pc-ease);
  }
  .product-link-2:hover .product-card-circle {
    opacity: 1;
    transform: scale(1);
  }
  /* arrow points right (→) while hidden, then rotates up to aim at the
     top-right corner (↗) as it reveals */
  .product-card-circle svg {
    width: 26px; /* Tier-2: off-scale icon (parity) */
    height: 26px;
    color: #202318; /* --color-charcoal-825 */
    stroke: #202318;
    transform: rotate(45deg);
    transition: transform var(--pc-dur) var(--pc-ease);
  }
  .product-link-2:hover .product-card-circle svg {
    transform: rotate(0deg);
  }
  /* Figma trigger: Mouse enter · 100ms delay — hover-IN only (0s at rest) */
  .product-link-2::before,
  .product-box-6,
  .product-img,
  .product-card-circle,
  .product-card-circle svg,
  .product-label {
    transition-delay: var(--pc-delay);
  }
  @media (prefers-reduced-motion: reduce) {
    .product-link-2::before,
    .product-box-6,
    .product-img,
    .product-card-circle,
    .product-card-circle svg,
