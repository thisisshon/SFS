---
/**
 * Investor Charter — /investor-charter/
 * Mandatory-disclosure document listing. Pixel parity with legacy
 * investor-charter.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title:
    'Investor Charter — Mandatory Disclosures & Compliance Documents | Shriram Financial Services',
  description:
    'All mandatory disclosures, investor rights, grievance mechanisms and compliance documents from Shriram Financial Services — Research Analyst, PMS, Stock Brokers, DP NSDL and DP CDSL — in one place. View online or download as PDF.',
  path: '/investor-charter/',
};

// The five charter documents (name → grid card).
const CHARTERS = ['Research Analyst', 'PMS', 'Stock Brokers', 'DP NSDL', 'DP CDSL'];
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Investor <span class="g">Charter</span></h1>
      <p class="lead">
        All mandatory disclosures, investor rights, grievance mechanisms and compliance documents
        — in one place. View online or download as PDF.
      </p>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">SEBI-mandated</span>
          </div>
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">Updated Jun 2026</span>
          </div>
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">View or download as PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= CHARTER DOCUMENTS ================= -->
  <section class="section stack sec-light" id="sec-charters" data-section="charters">
    <div class="stack" style="gap:16px">
      <h2 class="sub-title">Charter Documents</h2>
      <p class="sub-lead">
        Each charter sets out our services, investor rights and responsibilities, timelines and the
        grievance-redressal process for that activity. Read online, or download the signed PDF for
        your records.
      </p>
    </div>

    <div class="doc-grid">
      {
        CHARTERS.map((name) => (
          <article class="doc-card">
            <h3 class="nm">{name}</h3>
            <span class="upd">PDF<span class="sep">·</span>Updated Jun 2026</span>
            <div class="doc-links">
              <a class="doc-dl" href="#" aria-label={`View Investor Charter — ${name}`}>View</a>
              <a class="doc-dl" href="#" download aria-label={`Download Investor Charter — ${name}`}>
                Download
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= IMPORTANT DISCLOSURE ================= -->
  <section class="section stack sec-tint" id="sec-disclosure" data-section="disclosure">
    <div class="disc-note">
      <svg class="disc-ico" aria-hidden="true" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle><path d="M12 7.5v.5M12 11v5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
      <p>
        <strong>Important Disclosure:</strong> Investments in securities markets are subject to market
        risks. Read all related documents carefully before investing. Shriram Financial Services
        Limited is registered with SEBI as a Stock Broker (Registration Nos. INB231103833,
        INB011103839), Research Analyst (INH000009624) and CDSL Depository Participant
        (IN-DP-165-2015). AMFI-registered Mutual Fund Distributor: ARN 29483. PFRDA-registered NPS
        Point of Presence. CIN: U65100TN1974PLC006603. Registered Office: Shriram House, No. 4,
        Burkit Road, T. Nagar, Chennai – 600 017.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Investor Charter — page-specific styles. Values reuse shared tokens. ===== */
  .section {
    scroll-margin-top: 96px;
  }

  /* charter documents use the shared .doc-grid / .doc-card component (global.css).
     Only the top margin below the intro copy is page-specific. */
  .doc-grid {
    margin-top: 32px;
  }

  /* important disclosure block */
  .disc-note {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: var(--container-pad);
  }
  .disc-note .disc-ico {
    width: 24px;
    height: 24px;
    flex: none;
    margin-top: 2px;
    color: var(--color-gold-400);
  }
  .disc-note p {
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-tertiary);
  }
  .disc-note strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .disc-note {
      flex-direction: column;
    }
  }
</style>
