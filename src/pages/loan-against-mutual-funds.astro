---
/**
 * Loan Against Mutual Funds - lead-capture landing - /loan-against-mutual-funds
 *
 * ISOLATED, single-screen lead-capture landing page (Figma node 14:26). Like its
 * sibling /open-demat-campaign1 it drops the shared site chrome (Header /
 * MegaNav / Footer) via BaseLayout's `chrome={false}` + `footer="custom"` seam,
 * so the whole page is one focused funnel: logo-only bar -> hero (persuasion +
 * eligibility form) -> disclaimer strip.
 *
 * Built 100% from the design system: the shared <Hero> two-column `aside`
 * layout (rule 18), the shared `.hf-field` input (rule 8), the global button
 * system (rule 17), Outfit (rule 3) and colour tokens (rule 9). The Figma's
 * `brand/orange #f5a623` maps to the site's brand gold `--color-gold-400`; its
 * photographic "Hero image (replace with asset)" placeholder is intentionally
 * served by the standardised hero gradient (rules 7/18) - no page fork.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';

const seo = {
  title: 'Loan Against Mutual Funds',
  description:
    'Get a Loan Against Mutual Funds for personal needs - pledge your holdings instead of selling. Interest from 10.5%* p.a., 100% paperless, from an RBI-regulated NBFC.',
  path: '/loan-against-mutual-funds',
  // Paid-campaign lead-capture variant - keep it out of the index so it never
  // competes with a canonical product page for the same intent. (No effect while
  // BaseLayout force-noindexes the pre-launch site; takes over once that block is
  // lifted and per-page `seo.noindex` gating is restored.)
  noindex: true,
};
---

<BaseLayout seo={seo} chrome={false} footer="custom" mainClass="lamf-main">
  <!-- ===== logo-only bar (isolated: no mega-nav) ===== -->
  <header class="lamf-nav">
    <a href="/" class="nav-logo-link" aria-label="Shriram Credit - home">
      <div class="logo-box">
        <div class="logo-crop">
          <img src="/assets/logo.svg" alt="Shriram Credit" width="128" height="52" />
        </div>
      </div>
    </a>
  </header>

  <!-- ===== HERO: persuasion column + eligibility card ===== -->
  <Hero id="sec-hero" dataSection="lamf-hero">
    <Fragment slot="title">Get <span class="g">Loan Against Mutual Funds</span> for Personal Needs</Fragment>
    <Fragment slot="lead">Smart investors pledge. They don&rsquo;t sell.</Fragment>

    <!-- benefit bullets (default slot -> inside .hero-inner, under the lead) -->
    <ul class="lamf-benefits">
      <li class="lamf-benefit">
        <span class="lamf-benefit-ico" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle class="ring" cx="12" cy="12" r="11" />
            <path class="chk" d="M7.5 12.5l3 3 5.5-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="lamf-benefit-tx">Continue earning returns on your investments</span>
      </li>
      <li class="lamf-benefit">
        <span class="lamf-benefit-ico" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle class="ring" cx="12" cy="12" r="11" />
            <path class="chk" d="M7.5 12.5l3 3 5.5-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="lamf-benefit-tx">100% Paperless Process</span>
      </li>
      <li class="lamf-benefit">
        <span class="lamf-benefit-ico" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle class="ring" cx="12" cy="12" r="11" />
            <path class="chk" d="M7.5 12.5l3 3 5.5-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="lamf-benefit-tx">RBI-Regulated NBFC with 25 years of legacy</span>
      </li>
    </ul>

    <!-- eligibility card (aside slot -> right column via .hero-grid) -->
    <form class="lamf-form hero-aside" slot="aside" aria-label="Check Loan Against Mutual Funds eligibility" onsubmit="return false;">
      <!-- interest-rate banner -->
      <p class="lamf-rate">
        <span class="lamf-rate-lbl">Interest rate starting at</span>
        <span class="lamf-rate-val">10.5%* p.a.</span>
      </p>

      <!-- mobile number (shared .hf-field + country-code prefix) -->
      <div class="hf-field">
        <span class="lamf-cc" aria-hidden="true">IN&nbsp;+91</span>
        <span class="lamf-sep" aria-hidden="true"></span>
        <div class="hf-field-in">
          <label for="lamf-mobile">Mobile Number</label>
          <input id="lamf-mobile" name="mobile" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="00000 00000" required />
        </div>
      </div>

      <!-- consent -->
      <label class="lamf-consent">
        <input type="checkbox" name="terms" required />
        <span>I agree to the <a href="/terms-and-conditions">terms &amp; conditions</a> and authorise Shriram Credit to contact me</span>
      </label>

      <!-- primary CTA (full-width) -->
      <button class="btn btn-primary btn-xl" type="submit">
        Check Eligibility Now
        <svg class="btn-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </button>

      <p class="lamf-otp">We&rsquo;ll send an OTP to verify your number.</p>

      <!-- trust badge -->
      <div class="lamf-trust">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6l7-3Z" /><path d="M9 12l2 2 4-4" />
        </svg>
        <span>RBI-Regulated NBFC &middot; Trusted since 1999</span>
      </div>
    </form>
  </Hero>

  <!-- ===== disclaimer strip (custom footer) ===== -->
  <footer class="lamf-disclaimer">
    <p class="lamf-disc-text">
      <strong>Disclaimer:</strong> Loan Against Securities is intended only for personal use. The loan amount cannot be utilized for speculative activities, capital market-related purposes, or any anti-social purposes.
    </p>
  </footer>
</BaseLayout>

<style>
  /* ===== LAMF landing - page-scoped layout only. All colour via tokens, all
     type on the shared scale, spacing on the 8px grid. The input is the shared
     .hf-field (global.css); only the card + strip chrome live here. ===== */

  /* Single-screen funnel: bar (fixed) -> hero (grows) -> disclaimer (fixed).
     `main` is rendered by BaseLayout and `.hero` by the Hero component, so these
     cross-component rules are :global (scoped to this page via the unique
     `main.lamf-main` anchor - no other page uses that class). */
  :global(main.lamf-main) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  :global(main.lamf-main > .hero) {
    flex: 1;
  }

  /* ---- logo-only bar ---- */
  .lamf-nav {
    flex: none;
    height: 72px;
    padding: 0 var(--pad);
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border-card);
    display: flex;
    align-items: center;
  }
  .nav-logo-link { display: inline-flex; text-decoration: none; }

  /* ---- benefit bullets (on the dark hero) ---- */
  .lamf-benefits {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
  }
  .lamf-benefit { display: flex; align-items: center; gap: 16px; }
  .lamf-benefit-ico { flex: none; width: 24px; height: 24px; color: var(--color-gold-400); }
  .lamf-benefit-ico .ring { fill: currentColor; }
  .lamf-benefit-ico .chk { fill: none; stroke: var(--color-white); }
  .lamf-benefit-tx { font-weight: 600; font-size: 16px; color: var(--color-white); }

  /* ---- eligibility card (width + flex come from shared .hero-aside) ---- */
  .lamf-form {
    background: var(--color-white);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.22); /* sanctioned translucency: shadow only */
  }

  /* interest-rate banner */
  .lamf-rate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 20px;
    border-radius: 12px;
    background: var(--color-gold-100);
    text-align: center;
  }
  .lamf-rate-lbl { font-weight: 400; font-size: 14px; color: var(--color-text-secondary); }
  .lamf-rate-val { font-weight: 700; font-size: 18px; color: var(--color-gold-400); }

  /* country-code prefix inside the shared .hf-field (decoration only, rule 8) */
  .lamf-cc { flex: none; font-weight: 600; font-size: 14px; color: var(--color-text-primary); white-space: nowrap; }
  .lamf-sep { flex: none; width: 1px; height: 24px; background: var(--color-border-card); }

  /* consent - the whole label is the (larger) hit area; glyph stays 16px */
  .lamf-consent { display: flex; align-items: flex-start; gap: 8px; cursor: pointer; }
  .lamf-consent input {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    flex: none;
    accent-color: var(--color-olive-900);
    cursor: pointer;
  }
  .lamf-consent span { font-weight: 400; font-size: 13px; line-height: 1.5; color: var(--color-text-secondary); }
  .lamf-consent a { color: var(--color-gold-400); font-weight: 600; text-decoration: none; }

  .lamf-form .btn-primary { width: 100%; min-width: 0; } /* full-width submit: exempt from the 220px footprint */

  .lamf-otp { text-align: center; font-weight: 400; font-size: 14px; color: var(--color-text-secondary); }

  /* trust badge */
  .lamf-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    border-radius: 12px;
    background: var(--color-surface-section-light);
    color: var(--color-olive-900);
  }
  .lamf-trust span { font-weight: 500; font-size: 14px; color: var(--color-text-primary); }

  /* ---- disclaimer strip (dark, gold top rule - matches Figma) ---- */
  .lamf-disclaimer {
    flex: none;
    padding: 20px var(--pad);
    background: var(--color-surface-footer);
    border-top: 1px solid var(--color-gold-400);
  }
  .lamf-disc-text { font-weight: 400; font-size: 14px; line-height: 1.5; color: var(--color-white); }
  .lamf-disc-text strong { font-weight: 700; }

  @media (max-width: 767px) {
    .lamf-nav { height: 60px; }
    .lamf-benefits { margin-top: 32px; }
  }
</style>

<script>
  /* Digit-group the eligibility mobile field. Mirrors the sibling campaign page. */
  const mob = document.getElementById('lamf-mobile') as HTMLInputElement | null;
  if (mob) {
    mob.addEventListener('input', () => {
      let d = mob.value.replace(/\D/g, '');
      if (d.slice(0, 2) === '91') d = d.slice(2);
      d = d.slice(0, 10);
      mob.value = d ? (d.length > 5 ? d.slice(0, 5) + ' ' + d.slice(5) : d) : '';
    });
  }
</script>
