---
/**
 * /review-guide — ProoofKit direction / onboarding guide.
 *
 * A comprehensive walkthrough of ProoofKit for the teams who use it: what every
 * feature does, how to flag comments on the live site, the deploy-gated
 * lifecycle, and what each role sees.
 *
 * Rendered in the TOOL's OWN design language (the "Red Moon" red-and-black skin)
 * to match the dashboards — a self-themed, full-bleed dark page, NOT the host
 * BaseLayout/cream system. It imports the package design system (tokens.css +
 * components.css) exactly like the dashboard shims do, and composes the shared
 * .pk-* component classes + --pk-* tokens (sharp corners, scarce Rosso Corsa,
 * uppercase tracked labels).
 *
 * Gated on PROOFKIT_ENABLED; noindex like every ProoofKit route. Facts here track
 * the package README.md / CHANGELOG.md — keep in sync when the tool changes.
 */
import { PROOFKIT_ENABLED, TEAMS, ADMIN_TEAM, TEAM_COLORS } from '../plugins/proofkit/config';
import pkg from '../plugins/proofkit/package.json';
import './../plugins/proofkit/core/design/tokens.css'; // colour + theme system (Red Moon default)
import './../plugins/proofkit/core/design/components.css'; // shared .pk-* component classes

/* The exact team chips the tool renders, reproduced from ProoofKit's own palette. */
const teamChips = TEAMS.map((t) => ({ name: t, bg: TEAM_COLORS[t][0], fg: TEAM_COLORS[t][1] }));
const adminChip = { name: ADMIN_TEAM, bg: TEAM_COLORS[ADMIN_TEAM][0], fg: TEAM_COLORS[ADMIN_TEAM][1] };

/* How to leave a comment — four steps. */
const commentSteps = [
  { t: 'Sign in', d: 'Open /review, pick your Team, enter your key. The tab arms review mode.' },
  { t: 'Enter review', d: 'The page desaturates but stays scrollable; existing pins appear, numbered.' },
  { t: 'Click an element', d: 'Point at the exact text, image or button you want changed. A composer opens.' },
  { t: 'Write & direct', d: 'Describe the change, choose which team it’s “Direct to”, and post.' },
];

/* How a comment travels — the deploy-gated lifecycle. */
const lifecycleSteps = [
  { t: 'Raised', d: 'You post a comment. It’s Open — your team sees “Pending”.' },
  { t: 'Triaged', d: 'An admin reads it on /reviewdash with its AI change-prompt.' },
  { t: 'Actioned', d: 'The change is made in code and the live site is rebuilt.' },
  { t: 'Bucketed', d: 'Admin marks it Complete — it moves to the silent deploy bucket (still “Pending”).' },
  { t: 'Deployed', d: 'Deploy publishes the bucket, notifies your team, and it flips to “Done”.' },
];

const faqs = [
  {
    q: 'Do I need to install anything to review the site?',
    a: 'No. ProoofKit runs entirely in the browser. Visit <b>/review</b>, sign in with your team and key, and every page grows a <b>Comment</b> button. There is nothing to download and no extension to add.',
  },
  {
    q: 'Nothing happens when I open a normal page — is it broken?',
    a: 'That’s by design. The overlay is dormant until you sign in. A normal visitor never sees it. Go to <b>/review</b> (or add <b>/review</b> to any page’s URL) to arm review mode for that browser tab; add <b>?review=0</b> to sign out.',
  },
  {
    q: 'Can I edit or delete a comment I posted?',
    a: 'From the page, no — the overlay is <b>add-only</b>, so comments can’t be changed or removed there. You can add a threaded <b>reply</b> to clarify. Editing, re-routing and deleting are admin actions on the <b>/reviewdash</b> dashboard.',
  },
  {
    q: 'Why does my comment still say “Pending” after the admin fixed it?',
    a: 'Because of the <b>deploy gate</b>. Admins work behind the scenes — marking a change Complete only moves it into a silent bucket. Your team keeps seeing <b>Pending</b> until the batch is <b>Deployed</b> to the live site, at which point it flips to <b>Done</b> and you get a notification. You only ever see a change once it is actually live.',
  },
  {
    q: 'Who can see my team’s comments?',
    a: 'Your <b>/teamdash</b> shows only the comments <b>directed to your team</b>, plus your notifications — the Worker enforces this server-side from your team key, so there is no URL to leak. Admins (Builder) can see everything across all teams.',
  },
  {
    q: 'What is the “Direct to” dropdown for?',
    a: 'It routes the comment to the team that should <b>act</b> on it. It defaults to <b>Builder</b> (the admin, for on-site changes) and lists every team except your own. The comment then lands in that team’s <b>/teamdash</b> inbox “For Action”, tagged with a “<b>Raised By</b> &lt;your team&gt;” chip, and that team is <b>notified</b> the moment it arrives.',
  },
  {
    q: 'What is the AI change-prompt?',
    a: 'For every comment the backend generates a precise, developer-ready instruction describing the change — so a developer (or Claude Code) can action it without guesswork. Admins get it on every card and in the Master Log; the <b>directed team</b> now sees it too, inside a comment’s <b>detail view</b> (open a card), with its own copy button.',
  },
  {
    q: 'Does it work before the backend is set up?',
    a: 'Yes — in <b>local demo mode</b>. Without a Worker URL configured, comments live in your browser’s <b>localStorage</b> and any password is accepted, so the whole flow is testable. Once the Cloudflare Worker is wired up, everyone shares one live store.',
  },
];

const title = 'ProoofKit Review Guide';
const desc = 'How to use ProoofKit — sign in, flag comments on the live site, direct them to a team, and track them through the deploy gate until they go live.';
---

{PROOFKIT_ENABLED ? (
<html lang="en" data-pk-theme="red-moon">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <style is:inline>{`html,body{margin:0;background:#181818}`}</style>
  </head>
  <body>
    <div class="g">
      <!-- ================= TOP BAR ================= -->
      <header class="g-top">
        <a class="g-brand" href="/review-guide" aria-label="ProoofKit">
          <svg class="g-mark" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9l-4 4V5Z" fill="#da291c"/>
            <circle cx="12" cy="9.5" r="1.6" fill="#fff"/>
          </svg>
          <span class="g-word">ProoofKit</span>
          <span class="g-tag">Review Guide | <span class="g-tag-brand">Shriram FS</span></span>
        </a>
        <nav class="g-topnav">
          <a class="pk-btn pk-btn--ghost" href="/">Go to site</a>
          <a class="pk-btn pk-btn--primary" href="/review">Start reviewing</a>
        </nav>
      </header>

      <!-- ================= HERO ================= -->
      <section class="g-hero">
        <div class="g-hero-glow" aria-hidden="true"></div>
        <div class="g-wrap g-hero-in">
          <span class="pk-eyebrow">ProoofKit · content-review tool</span>
          <h1 class="g-display">The Review Guide</h1>
          <p class="g-lead">
            ProoofKit lets any team walk the <b>live</b> site, drop a numbered comment on any element,
            and track that request all the way to production — no code, no screenshots, no email
            threads. This guide covers every feature: signing in, flagging changes, directing them to
            the right team, and the deploy gate that keeps “Done” honest.
          </p>
          <div class="g-cta-row">
            <a class="pk-btn pk-btn--primary" href="/review">Start reviewing</a>
            <a class="pk-btn pk-btn--ghost" href="/teamdash">Open my team dashboard</a>
          </div>
        </div>
      </section>

      <!-- ================= WHAT IT IS ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <span class="pk-eyebrow">Overview</span>
          <h2 class="g-h2">What ProoofKit is</h2>
          <p class="g-body g-measure">
            ProoofKit is a self-contained review tool built into this site. It has three moving parts that
            work together: an <b>on-page overlay</b> for leaving comments, <b>two dashboards</b> for
            tracking them, and a <b>deploy gate</b> that only shows your team a change once it is truly live.
            There is nothing to install — if it’s switched on, it lives quietly on every page and wakes up
            the moment you sign in.
          </p>

          <div class="g-grid g-mt">
            <article class="pk-card pk-card--hover g-feat">
              <span class="g-ic">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H8l-4 4V5a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2z"/></svg>
              </span>
              <h3 class="g-h3">On-page overlay</h3>
              <p class="g-body">Click-to-comment directly on the live page. Existing comments show as numbered
                pins anchored to their element; you add notes, replies and a target team without leaving the page.</p>
            </article>
            <article class="pk-card pk-card--hover g-feat">
              <span class="g-ic">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
              </span>
              <h3 class="g-h3">Two dashboards</h3>
              <p class="g-body">A per-<b>team</b> inbox (<b>/teamdash</b>) showing what’s directed to you and when it
                goes live, and an <b>admin</b> board (<b>/reviewdash</b>) where everything is triaged, actioned and deployed.</p>
            </article>
            <article class="pk-card pk-card--hover g-feat">
              <span class="g-ic">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <h3 class="g-h3">Deploy gate</h3>
              <p class="g-body">Admins work behind a curtain. A change is only marked <b>Done</b> for your team after
                it’s actually published to the live site — so status never lies about what you’ll see.</p>
            </article>
          </div>

          <div class="g-note g-mt">
            <p><b>Two ways it stores comments.</b> When the shared backend (a Cloudflare Worker) is connected,
              everyone reads and writes one live store. Without it, ProoofKit runs in <b>local demo mode</b> —
              comments live in your own browser and any password works — so the whole flow is testable before
              the backend exists.</p>
          </div>
        </div>
      </section>

      <!-- ================= TEAMS & ROLES ================= -->
      <section class="g-sec g-sec--alt">
        <div class="g-wrap">
          <span class="pk-eyebrow">Roles</span>
          <h2 class="g-h2">Who uses it — teams &amp; roles</h2>
          <p class="g-body g-measure">
            You sign in <b>once</b> per tab as one of the teams below. Your team is a chip that travels with
            every comment you make. There is also one admin identity, <b>{ADMIN_TEAM}</b>, that sees and
            controls everything.
          </p>

          <div class="g-teamrow g-mt">
            {teamChips.map((t) => (
              <span class="g-team" style={`background:${t.bg};color:${t.fg}`}>{t.name}</span>
            ))}
          </div>

          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">Teams — raise &amp; receive</h3>
              <p class="g-body">Product, SEO, Marketing, Content, Design and Business are ordinary teams. Any of them
                can walk the site and flag changes, and each has its own inbox at <b>/teamdash</b> for work directed
                to it. Teams see a <b>masked</b> view — just “Pending” or “Done”, never the admin’s internal status.</p>
            </article>
            <article class="pk-card">
              <h3 class="g-h3">
                Builder — the admin
                <span class="g-team g-team-sm" style={`background:${adminChip.bg};color:${adminChip.fg}`}>{adminChip.name}</span>
              </h3>
              <p class="g-body"><b>{ADMIN_TEAM}</b> is a login identity, not a team — it never appears in team filters, but it
                <b> is</b> the default target for on-site changes. Builder signs in to <b>/reviewdash</b> with the admin
                password and has full access: read every team’s comments, set status, re-route, deploy and delete.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ================= HOW TO COMMENT ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <span class="pk-eyebrow">The overlay</span>
          <h2 class="g-h2">Leaving a comment on the page</h2>
          <p class="g-body g-measure">
            The whole point of the overlay is that you review the <b>real</b> site — the exact page a visitor
            sees — and pin your feedback to the exact thing you’re talking about. Four steps:
          </p>

          <ol class="g-steps g-mt" style={`--n:${commentSteps.length}`}>
            {commentSteps.map((s, i) => (
              <li class="g-step">
                <span class="g-step-n">{String(i + 1).padStart(2, '0')}</span>
                <h4 class="g-step-t">{s.t}</h4>
                <p class="g-step-d">{s.d}</p>
              </li>
            ))}
          </ol>

          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">Signing in arms the tab</h3>
              <p class="g-body">Open <b>/review</b> — or add <b>/review</b> to the end of any page’s URL. You’ll get a
                two-field login: a <b>Team</b> dropdown and your <b>Key</b>. That choice is remembered for the whole
                tab, so you pick your team <b>once</b>, not per comment. Add <b>?review=0</b> to sign out.</p>
            </article>
            <article class="pk-card">
              <h3 class="g-h3">Review mode, on the live page</h3>
              <p class="g-body">Once armed, the site’s back-to-top button becomes a <b>Comment</b> button on every page.
                The page turns grayscale (so pins stand out) but stays fully scrollable. Existing comments appear as
                <b> numbered pins</b> that re-anchor to their element as the page reflows.</p>
            </article>
          </div>

          <h3 class="g-h3 g-mt">Everything the overlay gives you</h3>
          <div class="g-grid g-mt-sm">
            <article class="pk-card g-mini"><h4 class="g-mini-t">Click-to-comment</h4><p class="g-body">Click any element — a headline, a price, a button — to open the composer anchored to it.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Numbered pins</h4><p class="g-body">Every comment is a pin that tracks its element across scroll and layout changes.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">“Direct to” a team</h4><p class="g-body">Pick which team should action the change (defaults to Builder). More on this below.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Threaded replies</h4><p class="g-body">Anyone in review can reply on a pin to add context or agree — replies inherit the target team.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Comment navigator</h4><p class="g-body">A count plus prev/next controls step you through every pin on the page in order.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Deep links</h4><p class="g-body">Each pin has a shareable <b>#c=&lt;id&gt;</b> link that opens the page and jumps straight to it.</p></article>
          </div>

          <div class="g-note g-mt">
            <p><b>The overlay is add-only.</b> You can post comments and replies, but never edit or delete them from
              the page — that keeps the record trustworthy. Corrections and clean-up happen admin-side on the dashboard.</p>
          </div>
        </div>
      </section>

      <!-- ================= DIRECTING ================= -->
      <section class="g-sec g-sec--alt">
        <div class="g-wrap">
          <span class="pk-eyebrow">Routing</span>
          <h2 class="g-h2">Directing a comment (From → To)</h2>
          <p class="g-body g-measure">
            Every comment carries a <b>route</b>: the team that <b>raised</b> it and the team it’s <b>directed to</b>
            for action. You set the destination with the composer’s <b>“Direct to”</b> dropdown — it’s the first
            thing you choose, so you decide the direction before you write.
          </p>

          <div class="g-route g-mt" role="img" aria-label="Route: from your team, directed to Builder">
            <span class="g-team" style={`background:${teamChips[0].bg};color:${teamChips[0].fg}`}>Your team</span>
            <span class="g-arrow" aria-hidden="true">
              <svg viewBox="0 0 44 16" width="44" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h38"/><path d="M34 3l6 5-6 5"/></svg>
            </span>
            <span class="g-team" style={`background:${adminChip.bg};color:${adminChip.fg}`}>{ADMIN_TEAM}</span>
            <span class="g-route-note">default — on-site changes go to the admin</span>
          </div>

          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">How the list behaves</h3>
              <p class="g-body">“Direct to” lists every team <b>except your own</b> — you can’t direct work at yourself.
                It defaults to <b>Builder</b> (the admin) for on-site changes. If <b>you</b> are Builder, Builder drops
                out and it falls back to the first team, so the control is never empty.</p>
            </article>
            <article class="pk-card">
              <h3 class="g-h3">Where it lands</h3>
              <p class="g-body">A directed comment appears in the destination team’s <b>/teamdash</b> under <b>“For Action”</b>,
                tagged with a <b>“Raised By &lt;your team&gt;”</b> chip so they know who raised it, and that team is notified on
                arrival. Replies inherit the root’s direction. Admins can re-route a comment’s From/To later if needed.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ================= LIFECYCLE ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <span class="pk-eyebrow">The deploy gate</span>
          <h2 class="g-h2">How a comment travels</h2>
          <p class="g-body g-measure">
            This is the most important idea in ProoofKit. A comment carries <b>two truths</b>: the admin’s internal
            <b> working status</b>, and <b>what your team sees</b>. They’re deliberately kept apart — nothing an admin
            does is visible to your team until the change is actually <b>deployed</b> to the live site.
          </p>

          <ol class="g-steps g-mt" style={`--n:${lifecycleSteps.length}`}>
            {lifecycleSteps.map((s, i) => (
              <li class="g-step">
                <span class="g-step-n">{String(i + 1).padStart(2, '0')}</span>
                <h4 class="g-step-t">{s.t}</h4>
                <p class="g-step-d">{s.d}</p>
              </li>
            ))}
          </ol>

          <div class="g-grid-2 g-mt">
            <article class="pk-card g-truth g-truth--team">
              <p class="g-truth-tag">What your team sees</p>
              <div class="g-legend"><span class="g-dot g-dot-pending"></span><span>“Pending” — from the moment you post until it’s deployed</span></div>
              <div class="g-legend"><span class="g-dot g-dot-done"></span><span>“Done” — only after Deploy publishes it live</span></div>
              <p class="g-body g-mt-sm">Simple by design. Two states, no internal detail, no false “fixed” before it’s real.</p>
            </article>
            <article class="pk-card g-truth g-truth--admin">
              <p class="g-truth-tag">What admins track (behind the gate)</p>
              <div class="g-legend"><span class="g-dot g-dot-open"></span><span><b>Open</b> — raised, not yet actioned</span></div>
              <div class="g-legend"><span class="g-dot g-dot-bucket"></span><span><b>In bucket</b> — marked Complete, waiting to deploy</span></div>
              <div class="g-legend"><span class="g-dot g-dot-done"></span><span><b>Deployed</b> — published live, team notified</span></div>
              <div class="g-legend"><span class="g-dot g-dot-closed"></span><span><b>Closed</b> — actioned without a content change</span></div>
            </article>
          </div>

          <div class="g-note g-mt">
            <p><b>Completion validation.</b> When a comment includes replacement copy and an admin marks it Complete,
              the backend fetches the live page and checks the new wording is actually present. If it isn’t yet, the
              card shows a ⚠ flag — completing is still allowed (the site may be redeployed after), and the check can
              be re-run. This is why “Done” is trustworthy.</p>
          </div>
        </div>
      </section>

      <!-- ================= TEAM DASHBOARD ================= -->
      <section class="g-sec g-sec--alt">
        <div class="g-wrap">
          <span class="pk-eyebrow">/teamdash</span>
          <h2 class="g-h2">Your team dashboard</h2>
          <p class="g-body g-measure">
            One route serves every team; you’re identified by your <b>login key</b>, not the URL, so the backend
            returns <b>only your team’s</b> comments and notifications. There’s no per-team link to leak or guess.
          </p>
          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">A “For Action” inbox</h3>
              <p class="g-body">Everything <b>directed to your team</b> lands here, each card showing a <b>Raised By &lt;team&gt;</b>
                chip and an <b>Open Pin</b> link to see it on the live page. <b>Search</b>, <b>sort</b>, filter by status or by the
                team that raised it, and <b>open any card</b> for the full detail — reviewer, the <b>AI change-prompt</b> (with
                copy), validation, and a Raised → Done history. You still see the <b>masked</b> status only (<b>Pending</b> until
                it’s live, then <b>Done</b>) — never the admin’s internal working status or deploy bucket.</p>
            </article>
            <article class="pk-card">
              <h3 class="g-h3">Live notifications</h3>
              <p class="g-body">You’re notified the moment a comment is <b>directed to your team</b>, and again when your own
                comments go <b>live</b> — each notification carries an <b>Open Pin</b> link, unread badges and a per-item
                read/unread toggle. If you need admin access, an <b>“Upgrade access to admin”</b> link at the bottom takes you
                to the admin sign-in.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ================= ADMIN DASHBOARD ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <span class="pk-eyebrow">/reviewdash</span>
          <h2 class="g-h2">The admin dashboard</h2>
          <p class="g-body g-measure">
            Builder’s command centre. Sign in at <b>/review</b> (or pick Builder in the <b>/teamdash</b> login). The
            left sidebar has four areas: <b>Overview · Deploy · Notifications · Master Log</b>.
          </p>

          <div class="g-grid g-mt">
            <article class="pk-card g-mini"><h3 class="g-mini-t">Overview</h3><p class="g-body">The open worklist — <b>All / By Page / Open / Deployed / Closed</b> tabs, “From” team filter chips and live counts. Each card has <b>Open Pin</b> and a <b>Copy prompt</b> button. Completed-but-unpublished (bucket) comments live only under <b>Deploy</b>, not here. The left edge is colour-keyed to lifecycle state.</p></article>
            <article class="pk-card g-mini"><h3 class="g-mini-t">Deploy</h3><p class="g-body">The bucket of completed/closed-but-unpublished comments plus a batch <b>Deploy</b> button. Deploying publishes the whole bucket at once and fires each team’s notifications.</p></article>
            <article class="pk-card g-mini"><h3 class="g-mini-t">Notifications</h3><p class="g-body">The full deploy/notification feed with unread tracking, a per-item read/unread toggle and “Mark all read”.</p></article>
            <article class="pk-card g-mini"><h3 class="g-mini-t">Master Log</h3><p class="g-body">The complete record — every root entry (When / Page / Element / Team / Status / Prompt), including deployed ones. Each row drills into a full detail view with a <b>status-history timeline</b> and a <b>More options</b> menu.</p></article>
          </div>

          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">What an admin can do</h3>
              <p class="g-body">Set a comment’s working status (<b>Mark Complete</b> / reopen / <b>Close</b>), which runs completion
                validation and drops it into the deploy bucket; <b>re-route</b> a comment’s From/To; <b>bulk-select</b> and act on
                many at once; <b>deploy</b> the bucket; and <b>delete</b> whole threads. Admins can also open any team’s board with an
                explicit “Admin view” ribbon.</p>
            </article>
            <article class="pk-card g-truth g-truth--red">
              <h3 class="g-h3">The AI change-prompt</h3>
              <p class="g-body">Every comment gets a precise, developer-ready instruction auto-generated by the backend — hand it
                to a developer or to Claude Code and the change can be made without guesswork. It sits on the admin card with a
                <b>copy button</b>, and the <b>directed team</b> sees it too inside a comment’s detail view.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ================= ACCESS ================= -->
      <section class="g-sec g-sec--alt">
        <div class="g-wrap">
          <span class="pk-eyebrow">Auth</span>
          <h2 class="g-h2">Access &amp; keys</h2>
          <p class="g-body g-measure">Two tiers of access, enforced by the backend — you never see anything you shouldn’t.</p>
          <div class="g-grid-2 g-mt">
            <article class="pk-card">
              <h3 class="g-h3">Reviewer key <span class="pk-chip">teams</span></h3>
              <p class="g-body">Lets you add comments, read a page’s pins, and — on <b>/teamdash</b> — read your own team’s
                comments and notifications. Your team key both signs you in <b>and</b> scopes what you can read to your team.
                Ask your admin for your team’s key.</p>
            </article>
            <article class="pk-card">
              <h3 class="g-h3">Admin password <span class="pk-chip pk-chip--red">Builder</span></h3>
              <p class="g-body">Unlocks the full <b>/reviewdash</b> — read every team’s comments, set status, deploy, delete, and
                see all notifications. Admin access is a superset of reviewer access, so an admin can also open any team’s scoped board.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ================= TIPS ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <span class="pk-eyebrow">Etiquette</span>
          <h2 class="g-h2">Tips for great comments</h2>
          <p class="g-body g-measure">A little precision here saves a round-trip later.</p>
          <div class="g-grid g-mt">
            <article class="pk-card g-mini"><h4 class="g-mini-t">Pin the exact element</h4><p class="g-body">Click the specific word, image or button — not the whole section. The tighter the anchor, the less ambiguous the fix.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Say the change, not just the problem</h4><p class="g-body">“Change ‘Apply now’ to ‘Open account’” beats “this button is wrong.” If you have the exact new copy, include it — the backend can even auto-verify it went live.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Direct it to the right team</h4><p class="g-body">Copy fix? Content. On-site build change? Builder. Getting the direction right lands it in the correct inbox first time.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Reply instead of re-posting</h4><p class="g-body">If a pin already exists for the thing you’re looking at, add a reply rather than a second pin — it keeps the thread together.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Trust “Pending”</h4><p class="g-body">Pending doesn’t mean ignored — the admin may have already fixed it. You’ll see “Done” the moment it’s genuinely live.</p></article>
            <article class="pk-card g-mini"><h4 class="g-mini-t">Share a pin</h4><p class="g-body">Use the <b>#c=&lt;id&gt;</b> deep link to point a teammate straight at a specific comment.</p></article>
          </div>
        </div>
      </section>

      <!-- ================= FAQ ================= -->
      <section class="g-sec g-sec--alt">
        <div class="g-wrap">
          <span class="pk-eyebrow">Help</span>
          <h2 class="g-h2">Got Questions?</h2>
          <div class="g-faq g-mt">
            {faqs.map((f) => (
              <details class="g-faq-item">
                <summary class="g-faq-q"><span>{f.q}</span><span class="g-faq-ico" aria-hidden="true"></span></summary>
                <div class="g-faq-a"><p set:html={f.a} /></div>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- ================= CTA ================= -->
      <section class="g-sec">
        <div class="g-wrap">
          <div class="g-band">
            <div class="g-hero-glow" aria-hidden="true"></div>
            <div class="g-band-in">
              <span class="pk-eyebrow">Get started</span>
              <h2 class="g-h2">Ready to flag your first change?</h2>
              <p class="g-body g-measure">Sign in, walk the page you care about, and drop a pin exactly where the change
                belongs. Your team dashboard tracks it from “Pending” to “Done”.</p>
              <div class="g-cta-row">
                <a class="pk-btn pk-btn--primary" href="/review">Start reviewing</a>
                <a class="pk-btn pk-btn--ghost" href="/teamdash">Open my team dashboard</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ================= FOOTER ================= -->
      <footer class="g-foot">
        <div class="g-wrap g-foot-in">
          <span class="g-brand">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9l-4 4V5Z" fill="#da291c"/>
              <circle cx="12" cy="9.5" r="1.6" fill="#fff"/>
            </svg>
            <span class="g-word">ProoofKit</span>
          </span>
          <span class="g-foot-meta">Content-review tool · v{pkg.version}</span>
        </div>
      </footer>
    </div>
  </body>
</html>
) : (
