<style>
  /* ===== /review-guide — the ProoofKit "Red Moon" skin. Layout only; every colour
     binds to a --pk-* token from the tool's design system (tokens.css). ===== */

  .g { background: var(--pk-canvas); color: var(--pk-ink); font-family: var(--pk-font);
    -webkit-font-smoothing: antialiased; min-height: 100vh; }
  .g :global(b) { color: var(--pk-ink); font-weight: 600; }

  .g-wrap { width: 100%; max-width: 1120px; margin-inline: auto; padding-inline: clamp(20px, 5vw, 48px); }

  /* ---- top bar ---- */
  .g-top { display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 16px clamp(20px, 5vw, 48px); border-bottom: 1px solid var(--pk-hair);
    background: var(--pk-canvas); position: sticky; top: 0; z-index: 20; flex-wrap: wrap; }
  .g-brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; color: var(--pk-ink); }
  .g-mark { flex: none; }
  .g-word { font-weight: 700; font-size: 15px; letter-spacing: .06em; text-transform: uppercase; }
  .g-tag { font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase;
    color: var(--pk-muted); padding-left: 12px; margin-left: 4px; border-left: 1px solid var(--pk-hair); }
  .g-tag-brand { color: var(--pk-red); }
  .g-topnav { display: flex; align-items: center; gap: 12px; }
  .g-topnav .pk-btn { height: 42px; padding: 0 20px; font-size: 12px; }

  /* ---- hero ---- */
  .g-hero { position: relative; overflow: hidden; border-bottom: 1px solid var(--pk-hair);
    padding-block: clamp(64px, 12vw, 132px); }
  .g-hero-glow { position: absolute; inset: 0; pointer-events: none; }
  .g-hero-glow::before { content: ""; position: absolute; top: -160px; left: 12%;
    width: 620px; height: 520px; max-width: 90%;
    background: radial-gradient(circle, rgba(218,41,28,.20), rgba(218,41,28,0) 66%); }
  .g-hero-in { position: relative; }
  .g-display { margin: 20px 0 0; font-weight: 500; letter-spacing: -0.03em; line-height: 1.03;
    font-size: clamp(44px, 9vw, 88px); color: var(--pk-ink); max-width: 15ch; }
  .g-lead { margin: 24px 0 0; max-width: 62ch; font-size: clamp(16px, 2.1vw, 19px);
    line-height: 1.6; color: var(--pk-body); font-weight: 400; }
  .g-cta-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 36px; }

  /* ---- sections ---- */
  .g-sec { padding-block: clamp(56px, 9vw, 96px); border-bottom: 1px solid var(--pk-hair); }
  .g-sec--alt { background: #1b1b1b; }
  .g-h2 { margin: 16px 0 0; font-weight: 500; letter-spacing: -0.02em; line-height: 1.12;
    font-size: clamp(28px, 5vw, 42px); color: var(--pk-ink); }
  .g-h3 { margin: 0; font-weight: 600; font-size: 19px; letter-spacing: -0.01em; color: var(--pk-ink); }
  .g-body { font-size: 15px; line-height: 1.62; color: var(--pk-body); font-weight: 400; }
  .g-measure { max-width: 72ch; margin-top: 18px; }
  .g-mt { margin-top: 40px; }
  .g-mt-sm { margin-top: 16px; }

  /* ---- grids + cards ---- */
  .g-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
  .g-grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
  .pk-card { display: flex; flex-direction: column; gap: 12px; }
  .g-feat { gap: 14px; }
  .g-mini { gap: 8px; }
  .g-mini-t { margin: 0; font-weight: 600; font-size: 16px; color: var(--pk-ink); }

  /* icon square — hairline, scarce red glyph */
  .g-ic { width: 46px; height: 46px; flex: none; display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--pk-hair); color: var(--pk-red); background: var(--pk-input); }
  .g-ic svg { display: block; }

  /* ---- numbered steps ---- */
  .g-steps { list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(var(--n), minmax(0, 1fr)); gap: 0; }
  .g-step { position: relative; padding: 22px 24px; border: 1px solid var(--pk-hair);
    border-left: none; display: flex; flex-direction: column; gap: 10px; background: var(--pk-card); }
  .g-step:first-child { border-left: 2px solid var(--pk-red); }
  .g-step-n { font-weight: 700; font-size: 13px; letter-spacing: 2px; color: var(--pk-red); }
  .g-step-t { margin: 0; font-weight: 600; font-size: 16px; color: var(--pk-ink); }
  .g-step-d { margin: 0; font-size: 13.5px; line-height: 1.55; color: var(--pk-body); }

  /* ---- team chips (ProoofKit's own palette) ---- */
  .g-teamrow { display: flex; flex-wrap: wrap; gap: 10px; }
  .g-team { display: inline-flex; align-items: center; justify-content: center; min-width: 92px;
    padding: 7px 16px; font-weight: 700; font-size: 12px; letter-spacing: .04em; }
  .g-team-sm { min-width: 0; margin-left: 10px; font-size: 11px; padding: 4px 10px; vertical-align: middle; }

  /* ---- From → To route ---- */
  .g-route { display: flex; flex-wrap: wrap; align-items: center; gap: 16px;
    padding: 22px 24px; border: 1px solid var(--pk-hair); border-left: 2px solid var(--pk-red); background: var(--pk-card); }
  .g-arrow { color: var(--pk-muted); display: inline-flex; }
  .g-arrow svg { display: block; }
  .g-route-note { font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--pk-muted); }

  /* ---- two-truths + legend ---- */
  .g-truth { gap: 14px; }
  .g-truth--team { border-left: 2px solid var(--pk-green); }
  .g-truth--admin { border-left: 2px solid var(--pk-amber); }
  .g-truth--red { border-left: 2px solid var(--pk-red); }
  .g-truth-tag { margin: 0; font-weight: 700; font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase; color: var(--pk-muted); }
  .g-legend { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; line-height: 1.5; color: var(--pk-body); }
  .g-dot { width: 11px; height: 11px; flex: none; border-radius: 50%; margin-top: 4px; }
  .g-dot-pending, .g-dot-open { background: var(--pk-amber); }
  .g-dot-bucket { background: var(--pk-blue); }
  .g-dot-done { background: var(--pk-green); }
  .g-dot-closed { background: var(--pk-muted); }

  /* ---- callout note ---- */
  .g-note { border: 1px solid var(--pk-hair); border-left: 2px solid var(--pk-red);
    background: var(--pk-elev); padding: 22px 24px; }
  .g-note p { margin: 0; font-size: 14.5px; line-height: 1.6; color: var(--pk-body); }

  /* ---- FAQ (native details, sharp) ---- */
  .g-faq { border-top: 1px solid var(--pk-hair); }
  .g-faq-item { border-bottom: 1px solid var(--pk-hair); background: var(--pk-card); }
  .g-faq-q { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between;
    gap: 20px; padding: 20px 24px; font-weight: 600; font-size: 16px; color: var(--pk-ink); }
  .g-faq-q::-webkit-details-marker { display: none; }
  .g-faq-ico { position: relative; width: 16px; height: 16px; flex: none; }
  .g-faq-ico::before, .g-faq-ico::after { content: ""; position: absolute; background: var(--pk-red);
    transition: transform .2s var(--pk-ease); }
  .g-faq-ico::before { left: 0; top: 7px; width: 16px; height: 2px; }
  .g-faq-ico::after { left: 7px; top: 0; width: 2px; height: 16px; }
  .g-faq-item[open] .g-faq-ico::after { transform: scaleY(0); }
  .g-faq-a { padding: 0 24px 22px; }
  .g-faq-a p { margin: 0; font-size: 14.5px; line-height: 1.65; color: var(--pk-body); max-width: 80ch; }

  /* ---- CTA band ---- */
  .g-band { position: relative; overflow: hidden; border: 1px solid var(--pk-hair);
    border-left: 2px solid var(--pk-red); background: var(--pk-card); padding: clamp(40px, 6vw, 72px); }
  .g-band .g-hero-glow::before { top: -220px; left: 30%; }
  .g-band-in { position: relative; }

  /* ---- footer ---- */
  .g-foot { padding-block: 40px; }
  .g-foot-in { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .g-foot-meta { font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--pk-muted); }

  /* ---- responsive: collapse steppers + tighten type ---- */
  @media (max-width: 900px) {
    .g-steps { grid-template-columns: 1fr; }
    .g-step { border-left: 2px solid var(--pk-hair); }
    .g-step:first-child { border-left: 2px solid var(--pk-red); }
    .g-step:not(:first-child) { border-top: none; }
  }
  @media (max-width: 600px) {
    .g-top { gap: 12px; }
    .g-tag { display: none; }
    .g-topnav { width: 100%; }
    .g-topnav .pk-btn { flex: 1; }
  }
</style>
