---
/**
 * /review3 — Proofkit 3.0 reviewer entry for the HOMEPAGE. A redirect stub, not a
 * page: it arms v3 auto-review and bounces to `/`, where the v3 on-page overlay
 * opens the Proofkit login and then review mode, rewriting the address bar back to
 * /review3. Gated on the v3 package's PROOFKIT_ENABLED. Every OTHER page uses
 * /<page>/review3, routed by 404.astro. All the logic lives in the isolated v3
 * package (src/plugins/proofkit-v3/); this is a thin seam. v2 stays at /review.
 */
import { PROOFKIT_ENABLED } from '../plugins/proofkit-v3/config';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Proofkit 3.0</title>
    {PROOFKIT_ENABLED && (
      <script is:inline>
        try { sessionStorage.setItem('pk3AutoReview', '1'); } catch (e) {}
        location.replace('/');
      </script>
    )}
  </head>
  <body></body>
</html>
