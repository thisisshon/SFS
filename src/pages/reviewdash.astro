---
/**
 * /reviewdash - route shim for Proofkit (admin dashboard).
 *
 * Proofkit's dashboard is a self-themed, full-bleed app, so this route renders its
 * OWN minimal HTML shell instead of the host BaseLayout — it needs nothing from the
 * host layout but the document. All logic lives in the package (src/plugins/proofkit/).
 * Gated on PROOFKIT_ENABLED; when off it renders a bare noindex stub.
 * See src/plugins/proofkit/README.md.
 */
import ProofkitDashboard from '../plugins/proofkit/Dashboard.astro';
import { PROOFKIT_ENABLED, dashSeo } from '../plugins/proofkit/config';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{PROOFKIT_ENABLED ? dashSeo.title : 'Not Found'}</title>
    <style>html,body{margin:0;background:#141414}</style>
  </head>
  <body>
    {PROOFKIT_ENABLED && <ProofkitDashboard />}
  </body>
</html>
