---
/**
 * /teamdash3 - route shim for Proofkit 3.0 (per-team dashboard, isolated build).
 *
 * The v3 clone of the content-review tool lives in src/plugins/proofkit-v3/ and is
 * completely isolated from the v2 default (own routes, own storage keys, own worker
 * URL env). Like /teamdash, this renders the tool's OWN minimal HTML shell instead
 * of the host BaseLayout. Gated on the v3 package's PROOFKIT_ENABLED; when off it
 * renders a bare noindex stub. See src/plugins/proofkit-v3/README.md.
 */
import ProofkitTeamDashboard from '../plugins/proofkit-v3/TeamDashboard.astro';
import { PROOFKIT_ENABLED, teamDashSeo } from '../plugins/proofkit-v3/config';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{PROOFKIT_ENABLED ? teamDashSeo.title + ' 3.0' : 'Not Found'}</title>
    <!-- Outfit — the tool's single typeface (rule 3); the app renders in its own shell,
         so it loads the font here rather than via the host BaseLayout. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300..800&display=swap" rel="stylesheet" />
    <!-- pre-paint floor mirrors --pk-floor (literal: paints before any stylesheet loads) -->
    <style>html,body{margin:0;background:#141414}</style>
  </head>
  <body>
    {PROOFKIT_ENABLED && <ProofkitTeamDashboard />}
  </body>
</html>
