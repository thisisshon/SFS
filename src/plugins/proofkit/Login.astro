---
/**
 * Proofkit Login - the /review auth gate.
 *
 * Front door for the dashboard: shows a login overlay asking for the admin
 * password, validates it against the Cloudflare Worker (WORKER_URL) - or accepts
 * anything in localStorage demo mode - then redirects to /reviewdash. The
 * dashboard (Dashboard.astro) keeps its own gate, so this is the entry point,
 * not the only guard. Rendered by the src/pages/review.astro route shim, gated
 * on PROOFKIT_ENABLED (./config.ts).
 *
 * THIN ADAPTER: logic lives in ./core/login.js and styles in ./core/login.css
 * (framework-neutral). This file mounts the gate shell, bridges the Worker URL,
 * and loads the core.
 */
import { WORKER_URL } from './config';
import './core/design/tokens.css';       // colour + theme tokens (login.css binds to --pk-*)
import './core/login.css';
---

<section class="section rvd-gate">
  <p class="rvd-gate-note">Content review is restricted. Sign in to continue.</p>
</section>

{/* Bridge the build-time Worker URL to the framework-neutral core (window global). */}
<script is:inline set:html={`window.PROOFKIT_WORKER_URL=${JSON.stringify(WORKER_URL)}`}></script>
<script>import './core/login.js';</script>
